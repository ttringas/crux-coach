# direnv configuration — committed to git so every worktree picks it up.
#
# Loads shared dev secrets from the canonical location outside the repo,
# so you don't need to copy/symlink .env files into each git worktree.
#
# Setup (one-time per machine): brew install direnv && add `eval "$(direnv hook zsh)"` to ~/.zshrc
# Setup (one-time per worktree): run `direnv allow` after cd-ing in.

# Shared development secrets (ANTHROPIC_API_KEY, etc.)
dotenv_if_exists ~/code/crux-coach/.env

# Per-worktree overrides (gitignored). Useful for testing different API keys
# or feature flags on a single branch without affecting other worktrees.
dotenv_if_exists .envrc.local
