<div class="border-t border-slate-800 pt-3">
  <div class="text-xs uppercase tracking-wide text-slate-400">Calibrate today's session</div>
  <p class="text-xs text-slate-500 mt-1">
    Your coach will use your soreness ratings above plus any details below to adjust today's exercises.
    Mention minor injuries, missing equipment, or anything else affecting today.
  </p>
  <%= form_with url: calibrate_weekly_plan_planned_session_path(planned_session.weekly_plan, planned_session),
        method: :post,
        local: false,
        data: { action: "submit->session-calibrator#submit", turbo_method: :post } do |f| %>
    <textarea name="feedback"
      rows="3"
      placeholder="e.g. Right shoulder is a bit tweaky from yesterday, no campus board access today, want to keep volume light…"
      class="mt-3 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100"
      data-session-calibrator-target="feedback"><%= planned_session.calibration_feedback if planned_session.calibration_status == "failed" %></textarea>

    <button type="submit"
      class="mt-3 w-full sm:w-auto min-h-11 inline-flex items-center justify-center gap-2 bg-amber-500 text-slate-950 px-4 py-2 rounded-md font-semibold hover:bg-amber-400 active:bg-amber-600 transition disabled:opacity-50 disabled:cursor-not-allowed"
      data-session-calibrator-target="submitButton">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.94 6.94a.75.75 0 011.06 0l2.5 2.5a.75.75 0 010 1.06l-2.5 2.5a.75.75 0 11-1.06-1.06L10.88 10 8.94 8.06a.75.75 0 010-1.12z" clip-rule="evenodd" />
      </svg>
      <span data-session-calibrator-target="submitLabel">Calibrate</span>
    </button>
  <% end %>
</div>
