<% logs_by_index = @planned_session.exercise_logs.index_by { |log| log["exercise_index"].to_i } %>

<div
  class="min-h-screen bg-slate-950 text-slate-100 px-4 py-6"
  data-controller="session-timer exercise-log session-completion demo-modal"
  data-session-timer-started-at-value="<%= @planned_session.started_at&.iso8601 %>"
  data-exercise-log-url-value="<%= weekly_plan_planned_session_path(@weekly_plan, @planned_session) %>"
  data-session-completion-url-value="<%= weekly_plan_planned_session_path(@weekly_plan, @planned_session) %>"
  data-action="session-status:updated->session-timer#statusUpdated"
>
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
      <%= link_to calendar_path(view: "weekly", week_of: @weekly_plan.week_of), class: "flex items-center justify-center h-10 w-10 rounded-lg bg-slate-800 border border-slate-700 text-slate-300 hover:text-slate-100 hover:border-slate-600 transition" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
      <% end %>
      <div>
        <div class="text-xs uppercase tracking-wide text-slate-400"><%= @planned_session.session_type %></div>
        <h1 class="text-2xl font-semibold"><%= @planned_session.title %></h1>
      </div>
    </div>
    <div class="text-right">
      <div class="text-xs text-slate-400">Status</div>
      <div class="text-sm text-slate-200" data-session-completion-target="statusLabel"><%= @planned_session.status.humanize %></div>
    </div>
  </div>

  <div class="flex flex-col items-center gap-2 mb-6">
    <div class="text-4xl font-semibold text-amber-400" data-session-timer-target="display">0:00</div>
    <div class="text-xs text-slate-500">Session timer</div>
  </div>

  <div class="bg-slate-900 border border-slate-800 rounded-2xl p-4 mb-6">
    <div class="flex flex-wrap items-center justify-between gap-3 text-sm text-slate-300">
      <div><span class="text-slate-500">Type:</span> <%= @planned_session.session_type.humanize %></div>
      <div><span class="text-slate-500">Intensity:</span> <%= @planned_session.intensity.humanize %></div>
      <div><span class="text-slate-500">Est. Duration:</span> <%= @planned_session.estimated_duration_minutes || "-" %> min</div>
    </div>
    <% if @planned_session.description.present? %>
      <div class="mt-3 pt-3 border-t border-slate-800 text-sm text-slate-300">
        <%= @planned_session.description %>
      </div>
    <% end %>
  </div>

  <div class="flex flex-wrap gap-3 mb-8">
    <%= button_tag "Start Session",
      type: "button",
      class: "bg-amber-500 text-slate-950 px-4 py-2 rounded-md font-semibold hover:bg-amber-400 active:bg-amber-600 transition #{@planned_session.todo? ? "" : "hidden"}",
      data: { action: "session-completion#start", session_completion_target: "startButton" } %>
    <%= button_tag "Complete Session",
      type: "button",
      class: "bg-emerald-400 text-slate-950 px-4 py-2 rounded-md font-semibold hover:bg-emerald-300 active:bg-emerald-500 transition #{@planned_session.in_progress? ? "" : "hidden"}",
      data: { action: "session-completion#complete", session_completion_target: "completeButton" } %>
    <%= button_tag "Skip Session",
      type: "button",
      class: "border border-slate-700 px-4 py-2 rounded-md text-slate-300 hover:border-slate-500 #{@planned_session.completed? || @planned_session.skipped? ? "hidden" : ""}",
      data: { action: "session-completion#skip", session_completion_target: "skipButton" } %>
  </div>

  <div class="flex items-center justify-between mb-3">
    <h2 class="text-lg font-semibold">Exercises</h2>
    <div class="text-xs text-slate-500" data-exercise-log-target="saveStatus"></div>
  </div>

  <div class="space-y-4">
    <% parse_duration = lambda do |value|
      raw = value.to_s.strip
      if raw =~ /(\d+)\s*(sec|second)/i
        Regexp.last_match(1).to_i
      elsif raw =~ /(\d+)\s*(min|minute)/i
        Regexp.last_match(1).to_i * 60
      elsif raw =~ /^\d+$/
        raw.to_i
      else
        nil
      end
    end %>
    <% @planned_session.exercises.each_with_index do |exercise, index| %>
      <% log = logs_by_index[index] || {} %>
      <% completed = log["completed"] %>
      <% work_seconds = parse_duration.call(exercise["duration"]) %>
      <% rest_seconds = parse_duration.call(exercise["rest"]) %>
      <% prescribed_bits = [] %>
      <% if exercise["sets"].present? && exercise["reps"].present? %>
        <% prescribed_bits << "#{exercise["sets"]} x #{exercise["reps"]}" %>
      <% elsif exercise["sets"].present? %>
        <% prescribed_bits << "Sets: #{exercise["sets"]}" %>
      <% elsif exercise["reps"].present? %>
        <% prescribed_bits << "Reps: #{exercise["reps"]}" %>
      <% end %>
      <% prescribed_bits << "Duration: #{exercise["duration"]}" if exercise["duration"].present? %>
      <% prescribed_bits << "Rest: #{exercise["rest"]}" if exercise["rest"].present? %>

      <% num_sets = exercise["sets"].to_s.match?(/\A\d+\z/) ? exercise["sets"].to_i : 1 %>
      <% num_sets = 1 if num_sets <= 0 %>
      <% duration_hint = exercise["duration"].presence %>
      <% exercise_name = exercise["name"] || exercise["title"] || "Exercise" %>
      <% reps_label = exercise["reps"].present? ? exercise["reps"].to_s : nil %>
      <% library_match = @exercise_library_matches[index] %>

      <div
        class="rounded-xl border p-4 transition bg-slate-900 border-slate-800"
        data-exercise-index="<%= index %>"
      >
        <!-- Exercise header -->
        <div class="flex items-center justify-between mb-1 gap-3">
          <div class="font-semibold text-base"><%= exercise_name %></div>
          <div class="flex items-center gap-2">
            <% if library_match %>
              <button type="button"
                class="text-xs text-amber-300 border border-amber-400/40 rounded-md px-2 py-1 hover:bg-amber-500/10 transition"
                data-action="click->demo-modal#open"
                data-demo-modal-url="<%= library_match.youtube_embed_url %>"
                data-demo-title="<%= h exercise_name %>">
                Watch demo
              </button>
            <% end %>
            <% if duration_hint %>
              <div class="flex-shrink-0 text-xs text-slate-500 bg-slate-800 px-2 py-1 rounded"><%= duration_hint %></div>
            <% end %>
            <button type="button" class="text-xs text-slate-200 border border-slate-600/60 rounded-md px-2 py-1 hover:border-slate-400 transition" data-action="click->exercise-log#toggle">
              Notes
            </button>
          </div>
        </div>
        <% if exercise["notes"].present? %>
          <div class="text-xs text-slate-400 italic mb-3"><%= exercise["notes"] %></div>
        <% end %>

        <!-- Set rows -->
        <div class="space-y-2">
          <% num_sets.times do |set_idx| %>
            <% set_key = "#{index}_#{set_idx}" %>
            <% set_log = (@planned_session.exercise_logs.find { |l| l["set_key"] == set_key }) || {} %>
            <% set_done = set_log["completed"] %>
            <div class="flex items-center gap-3 rounded-lg px-3 py-2 transition <%= set_done ? 'bg-green-500/5 border border-green-500/20' : 'bg-slate-800/40 border border-slate-800' %>"
                 data-set-key="<%= set_key %>"
                 data-exercise-index="<%= index %>"
                 data-set-index="<%= set_idx %>">
              <!-- Checkbox -->
              <label class="flex-shrink-0">
                <input
                  type="checkbox"
                  class="h-5 w-5 rounded border-slate-700 bg-slate-900 text-emerald-400"
                  <%= "checked" if set_done %>
                  data-action="change->exercise-log#saveSet"
                  data-set-key="<%= set_key %>"
                />
              </label>
              <!-- Set info -->
              <div class="flex-1 text-sm">
                <% if num_sets > 1 %>
                  <span class="text-slate-300"><%= set_done ? "✓" : "" %> Set <%= set_idx + 1 %> of <%= num_sets %></span>
                  <% if reps_label %>
                    <span class="text-slate-500"> · <%= reps_label %></span>
                  <% end %>
                <% else %>
                  <span class="text-slate-300 <%= set_done ? 'line-through text-slate-500' : '' %>"><%= prescribed_bits.any? ? prescribed_bits.join(" · ") : "Complete" %></span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <% if work_seconds.present? || rest_seconds.present? %>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            <% if work_seconds.present? %>
              <% work_minutes = work_seconds / 60 %>
              <% work_remaining = work_seconds % 60 %>
              <div class="rounded-lg border border-slate-800 bg-slate-800/40 p-3" data-controller="countdown-timer">
                <div class="text-xs uppercase tracking-wide text-slate-400">Work Timer</div>
                <div class="mt-2 flex items-center gap-2 text-xs text-slate-400">
                  <input type="number" min="0" inputmode="numeric" class="w-16 rounded-md border border-slate-700 bg-slate-950 px-2 py-1 text-sm text-slate-100" value="<%= work_minutes %>" data-countdown-timer-target="minutes" />
                  <span>min</span>
                  <input type="number" min="0" max="59" inputmode="numeric" class="w-16 rounded-md border border-slate-700 bg-slate-950 px-2 py-1 text-sm text-slate-100" value="<%= work_remaining %>" data-countdown-timer-target="seconds" />
                  <span>sec</span>
                </div>
                <div class="mt-2 text-sm font-mono text-amber-400" data-countdown-timer-target="display">0:00</div>
                <button type="button" class="mt-2 inline-flex items-center justify-center rounded-md border border-amber-500/40 px-3 py-1 text-xs font-semibold text-amber-200 hover:bg-amber-500/10 transition" data-action="countdown-timer#start">
                  Start
                </button>
              </div>
            <% end %>
            <% if rest_seconds.present? %>
              <% rest_minutes = rest_seconds / 60 %>
              <% rest_remaining = rest_seconds % 60 %>
              <div class="rounded-lg border border-slate-800 bg-slate-800/40 p-3" data-controller="countdown-timer">
                <div class="text-xs uppercase tracking-wide text-slate-400">Rest Timer</div>
                <div class="mt-2 flex items-center gap-2 text-xs text-slate-400">
                  <input type="number" min="0" inputmode="numeric" class="w-16 rounded-md border border-slate-700 bg-slate-950 px-2 py-1 text-sm text-slate-100" value="<%= rest_minutes %>" data-countdown-timer-target="minutes" />
                  <span>min</span>
                  <input type="number" min="0" max="59" inputmode="numeric" class="w-16 rounded-md border border-slate-700 bg-slate-950 px-2 py-1 text-sm text-slate-100" value="<%= rest_remaining %>" data-countdown-timer-target="seconds" />
                  <span>sec</span>
                </div>
                <div class="mt-2 text-sm font-mono text-amber-400" data-countdown-timer-target="display">0:00</div>
                <button type="button" class="mt-2 inline-flex items-center justify-center rounded-md border border-amber-500/40 px-3 py-1 text-xs font-semibold text-amber-200 hover:bg-amber-500/10 transition" data-action="countdown-timer#start">
                  Start
                </button>
              </div>
            <% end %>
          </div>
        <% end %>

        <!-- Expandable notes -->
        <div class="mt-3 hidden pl-2" data-exercise-details>
          <div class="text-xs text-slate-400" data-controller="speech-input">
            <div class="flex items-center justify-between">
              <label for="exercise-notes-<%= index %>">Notes</label>
              <button type="button" class="text-[11px] uppercase tracking-wide text-slate-200 border border-slate-600/60 rounded-md px-2 py-1 hover:border-slate-400 transition" data-action="speech-input#toggle" data-speech-input-target="button">
                Voice
              </button>
            </div>
            <textarea id="exercise-notes-<%= index %>" rows="2" class="mt-1 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" data-action="blur->exercise-log#queueSave" data-exercise-log-field="notes" data-speech-input-target="input"><%= log["notes"] %></textarea>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-10 bg-slate-900 border border-slate-800 rounded-2xl p-4">
    <div data-controller="speech-input">
      <div class="flex items-center justify-between">
        <h3 class="text-sm font-semibold text-slate-200">Session Notes</h3>
        <button type="button" class="text-[11px] uppercase tracking-wide text-slate-200 border border-slate-600/60 rounded-md px-2 py-1 hover:border-slate-400 transition" data-action="speech-input#toggle" data-speech-input-target="button">
          Voice
        </button>
      </div>
      <textarea
        rows="4"
        class="mt-3 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100"
        data-exercise-log-target="sessionNotes"
        data-speech-input-target="input"
        data-action="blur->exercise-log#queueSave"
      ><%= @planned_session.session_notes %></textarea>
    </div>

    <div class="mt-6 grid gap-4">
      <label class="text-xs text-slate-400" data-controller="range-value">
        <div class="flex items-center justify-between">
          <span>RPE (1-10)</span>
          <span class="text-slate-200" data-range-value-target="output"></span>
        </div>
        <input
          type="range"
          min="1"
          max="10"
          value="<%= @planned_session.perceived_exertion || 6 %>"
          class="mt-2 w-full"
          data-range-value-target="input"
          data-exercise-log-target="perceivedExertion"
          data-action="input->range-value#update change->exercise-log#queueSave"
        />
      </label>
      <label class="text-xs text-slate-400" data-controller="range-value">
        <div class="flex items-center justify-between">
          <span>Energy level (1-5)</span>
          <span class="text-slate-200" data-range-value-target="output"></span>
        </div>
        <input
          type="range"
          min="1"
          max="5"
          value="<%= @planned_session.energy_level || 3 %>"
          class="mt-2 w-full"
          data-range-value-target="input"
          data-exercise-log-target="energyLevel"
          data-action="input->range-value#update change->exercise-log#queueSave"
        />
      </label>
      <label class="text-xs text-slate-400" data-controller="range-value">
        <div class="flex items-center justify-between">
          <span>Finger soreness (1-5)</span>
          <span class="text-slate-200" data-range-value-target="output"></span>
        </div>
        <input
          type="range"
          min="1"
          max="5"
          value="<%= @planned_session.finger_soreness || 2 %>"
          class="mt-2 w-full"
          data-range-value-target="input"
          data-exercise-log-target="fingerSoreness"
          data-action="input->range-value#update change->exercise-log#queueSave"
        />
      </label>
      <label class="text-xs text-slate-400" data-controller="range-value">
        <div class="flex items-center justify-between">
          <span>General soreness (1-5)</span>
          <span class="text-slate-200" data-range-value-target="output"></span>
        </div>
        <input
          type="range"
          min="1"
          max="5"
          value="<%= @planned_session.general_soreness || 2 %>"
          class="mt-2 w-full"
          data-range-value-target="input"
          data-exercise-log-target="generalSoreness"
          data-action="input->range-value#update change->exercise-log#queueSave"
        />
      </label>
    </div>
  </div>

  <div class="fixed inset-0 z-50 hidden bg-slate-950/80 p-4 backdrop-blur flex items-center justify-center" data-demo-modal-target="modal" data-action="click->demo-modal#closeOnBackdrop keydown@window->demo-modal#handleKeydown">
    <div class="w-full max-w-3xl rounded-2xl border border-slate-800 bg-slate-900 shadow-xl overflow-hidden">
      <div class="flex items-center justify-between px-4 py-3 border-b border-slate-800">
        <div class="text-sm font-semibold text-slate-200" data-demo-modal-target="title">Exercise Demo</div>
        <button type="button" class="text-slate-400 hover:text-slate-100 transition" data-action="demo-modal#close" aria-label="Close">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="relative w-full" style="padding-top: 56.25%">
        <iframe class="absolute inset-0 w-full h-full" title="Exercise demo" allow="autoplay; encrypted-media" allowfullscreen data-demo-modal-target="frame"></iframe>
      </div>
    </div>
  </div>
</div>
