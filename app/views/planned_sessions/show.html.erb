<% logs_by_index = @planned_session.exercise_logs.index_by { |log| log["exercise_index"].to_i } %>

<% if defined?(ActionCable) %>
  <%= turbo_stream_from @planned_session %>
<% end %>

<div
  class="min-h-screen bg-slate-950 text-slate-100 px-4 py-6"
  data-controller="session-timer exercise-log session-completion demo-modal session-exercises"
  data-session-timer-started-at-value="<%= @planned_session.started_at&.iso8601 %>"
  data-exercise-log-url-value="<%= weekly_plan_planned_session_path(@weekly_plan, @planned_session) %>"
  data-session-completion-url-value="<%= weekly_plan_planned_session_path(@weekly_plan, @planned_session) %>"
  data-session-exercises-url-value="<%= update_exercises_weekly_plan_planned_session_path(@weekly_plan, @planned_session) %>"
  data-session-exercises-exercises-value="<%= json_escape(@planned_session.exercises.to_json) %>"
  data-session-exercises-library-value="<%= json_escape(@exercise_library_entries.map { |entry| { id: entry.id, name: entry.name, category: entry.category, description: entry.description } }.to_json) %>"
  data-action="session-status:updated->session-timer#statusUpdated"
>
  <div class="flex flex-col gap-4 mb-6 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-start gap-3">
      <%= link_to calendar_path(view: "weekly", week_of: @weekly_plan.week_of), class: "flex items-center justify-center h-11 w-11 rounded-lg bg-slate-800 border border-slate-700 text-slate-300 hover:text-slate-100 hover:border-slate-600 transition" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
      <% end %>
      <div>
        <div class="text-xs uppercase tracking-wide text-slate-400"><%= @planned_session.session_type %></div>
        <h1 class="text-2xl font-semibold"><%= @planned_session.title %></h1>
      </div>
    </div>
    <div class="text-left sm:text-right">
      <div class="text-xs text-slate-400">Status</div>
      <% display_status = case @planned_session.status
        when "todo" then "Upcoming"
        when "in_progress" then "In Progress"
        when "completed" then "Completed"
        when "skipped" then "Skipped"
        else @planned_session.status.humanize
      end %>
      <div class="mt-1 inline-flex items-center rounded-full border border-slate-700 bg-slate-900 px-2.5 py-1 text-xs text-slate-200" data-session-completion-target="statusLabel"><%= display_status %></div>
    </div>
  </div>

  <div class="flex flex-col items-center gap-2 mb-6">
    <div class="text-4xl sm:text-5xl font-semibold text-amber-400" data-session-timer-target="display">0:00</div>
    <div class="text-xs text-slate-500">Session timer</div>
  </div>

  <div class="bg-slate-900 border border-slate-800 rounded-2xl p-4 mb-6">
    <div class="flex flex-wrap items-center justify-between gap-3 text-sm text-slate-300">
      <div><span class="text-slate-500">Type:</span> <%= @planned_session.session_type.humanize %></div>
      <div><span class="text-slate-500">Intensity:</span> <%= @planned_session.intensity.humanize %></div>
      <div><span class="text-slate-500">Est. Duration:</span> <%= @planned_session.estimated_duration_minutes || "-" %> min</div>
    </div>
    <% if @planned_session.description.present? %>
      <div class="mt-3 pt-3 border-t border-slate-800 text-sm text-slate-300">
        <%= @planned_session.description %>
      </div>
    <% end %>
  </div>

  <div class="mt-6 rounded-2xl border border-slate-800 bg-slate-900 p-4">
    <h3 class="text-sm font-semibold text-slate-200">Pre-Session Check-in</h3>
    <div class="mt-4 grid gap-4">
      <label class="text-xs text-slate-400" data-controller="range-value">
        <div class="flex items-center justify-between">
          <span>Energy level</span>
          <span class="text-slate-200" data-range-value-target="output"></span>
        </div>
        <input
          type="range"
          min="1"
          max="5"
          value="<%= @planned_session.energy_level || 3 %>"
          class="mt-2 w-full"
          data-range-value-target="input"
          data-exercise-log-target="energyLevel"
          data-action="input->range-value#update change->exercise-log#queueSave"
        />
        <div class="flex justify-between text-[10px] text-slate-500 mt-1"><span>Low</span><span>High</span></div>
      </label>
      <label class="text-xs text-slate-400" data-controller="range-value">
        <div class="flex items-center justify-between">
          <span>Finger soreness</span>
          <span class="text-slate-200" data-range-value-target="output"></span>
        </div>
        <input
          type="range"
          min="1"
          max="5"
          value="<%= @planned_session.finger_soreness || 2 %>"
          class="mt-2 w-full"
          data-range-value-target="input"
          data-exercise-log-target="fingerSoreness"
          data-action="input->range-value#update change->exercise-log#queueSave"
        />
        <div class="flex justify-between text-[10px] text-slate-500 mt-1"><span>None</span><span>Very sore</span></div>
      </label>
      <label class="text-xs text-slate-400" data-controller="range-value">
        <div class="flex items-center justify-between">
          <span>General soreness</span>
          <span class="text-slate-200" data-range-value-target="output"></span>
        </div>
        <input
          type="range"
          min="1"
          max="5"
          value="<%= @planned_session.general_soreness || 2 %>"
          class="mt-2 w-full"
          data-range-value-target="input"
          data-exercise-log-target="generalSoreness"
          data-action="input->range-value#update change->exercise-log#queueSave"
        />
        <div class="flex justify-between text-[10px] text-slate-500 mt-1"><span>None</span><span>Very sore</span></div>
      </label>
    </div>
  </div>

  <%= render "planned_sessions/calibration_panel", planned_session: @planned_session %>

  <div class="mt-8 grid gap-3 sm:flex sm:flex-wrap">
    <%= button_tag "Start Session",
      type: "button",
      class: "w-full sm:w-auto min-h-11 bg-amber-500 text-slate-950 px-4 py-2 rounded-md font-semibold hover:bg-amber-400 active:bg-amber-600 transition #{@planned_session.todo? ? "" : "hidden"}",
      data: { action: "session-completion#start", session_completion_target: "startButton" } %>
    <%= button_tag "Skip Session",
      type: "button",
      class: "w-full sm:w-auto min-h-11 border border-slate-700 px-4 py-2 rounded-md text-slate-300 hover:border-slate-500 #{@planned_session.todo? ? "" : "hidden"}",
      data: { action: "session-completion#skip", session_completion_target: "skipButton" } %>
  </div>

  <div class="flex items-center justify-between mb-3 mt-6">
    <h2 class="text-lg font-semibold">Exercises</h2>
    <div class="text-xs text-slate-500" data-exercise-log-target="saveStatus"></div>
  </div>

  <div class="space-y-4">
    <% parse_duration = lambda do |value|
      raw = value.to_s.strip
      if raw =~ /(\d+)\s*(sec|second)/i
        Regexp.last_match(1).to_i
      elsif raw =~ /(\d+)\s*(min|minute)/i
        Regexp.last_match(1).to_i * 60
      elsif raw =~ /^\d+$/
        raw.to_i
      else
        nil
      end
    end %>
    <% @planned_session.exercises.each_with_index do |exercise, index| %>
      <% log = logs_by_index[index] || {} %>
      <% completed = log["completed"] %>
      <% work_seconds = parse_duration.call(exercise["duration"]) %>
      <% rest_seconds = parse_duration.call(exercise["rest"]) %>
      <%# --- Build display values from new schema (with backward compat) --- %>
      <% target_reps = exercise["target_reps"].presence || exercise["reps"].presence %>
      <% rep_unit = exercise["rep_unit"].presence || "reps" %>
      <% target_grade = exercise["target_grade"].presence %>
      <% target_weight = exercise["target_weight"].presence %>
      <% rest_value = exercise["rest"].to_s.strip %>
      <% hide_rest = rest_value == "0s" || rest_value == "0" || rest_value.blank? %>

      <% prescribed_bits = [] %>
      <% if exercise["sets"].present? && target_reps.present? %>
        <% prescribed_bits << "#{exercise["sets"]} × #{target_reps} #{rep_unit}" %>
      <% elsif exercise["sets"].present? %>
        <% prescribed_bits << "Sets: #{exercise["sets"]}" %>
      <% elsif target_reps.present? %>
        <% prescribed_bits << "#{target_reps} #{rep_unit}" %>
      <% end %>
      <% prescribed_bits << "Duration: #{exercise["duration"]}" if exercise["duration"].present? %>
      <% prescribed_bits << "Rest: #{rest_value}" if !hide_rest %>

      <% num_sets = exercise["sets"].to_s.match?(/\A\d+\z/) ? exercise["sets"].to_i : 1 %>
      <% num_sets = 1 if num_sets <= 0 %>
      <% duration_hint = exercise["duration"].presence %>
      <% exercise_name = exercise["name"] || exercise["title"] || "Exercise" %>
      <%# reps_label removed — now using target_reps + rep_unit %>
      <% category = exercise["category"].to_s.downcase %>
      <% name_downcase = exercise_name.to_s.downcase %>
      <% has_weight_key = exercise.key?("weight") || exercise.key?("target_weight") %>
      <% weight_keywords = ["weighted", "squat", "press", "deadlift", "row", "curl", "bench", "overhead"] %>
      <% name_has_weight = weight_keywords.any? { |term| name_downcase.include?(term) } %>
      <% show_weight = has_weight_key || category == "strength" || name_has_weight || target_weight.present? %>
      <% if ["climbing", "hangboard", "board", "mobility", "cardio"].include?(category) && !has_weight_key && !name_has_weight && target_weight.blank? %>
        <% show_weight = false %>
      <% end %>
      <% recommended_weight = (exercise["target_weight"] || exercise["weight"]).presence&.to_s %>
      <% library_match = @exercise_library_matches[index] %>

      <div
        class="rounded-xl border p-4 transition bg-slate-900 border-slate-800"
        data-exercise-index="<%= index %>"
      >
        <!-- Exercise header -->
        <div class="flex items-start justify-between gap-3">
          <div>
            <div class="font-semibold text-base"><%= exercise_name %></div>
            <% if duration_hint %>
              <div class="mt-1 inline-flex items-center rounded-full bg-slate-800 px-2.5 py-1 text-xs text-slate-300">
                <span class="text-slate-500">Timer:</span>
                <span class="ml-1"><%= duration_hint %></span>
              </div>
            <% end %>
          </div>
          <div class="hidden sm:flex items-center gap-2 flex-wrap justify-end">
            <button type="button"
              class="text-xs text-slate-200 border border-slate-600/60 rounded-md px-2 py-1 hover:border-slate-400 transition"
              data-action="click->session-exercises#edit">
              Edit
            </button>
            <button type="button"
              class="text-xs text-slate-200 border border-slate-600/60 rounded-md px-2 py-1 hover:border-slate-400 transition"
              data-action="click->session-exercises#swap">
              Swap
            </button>
            <button type="button"
              class="text-xs text-rose-200 border border-rose-500/50 rounded-md px-2 py-1 hover:border-rose-400 transition"
              data-action="click->session-exercises#remove">
              Remove
            </button>
            <% if library_match %>
              <button type="button"
                class="text-xs text-amber-300 border border-amber-400/40 rounded-md px-2 py-1 hover:bg-amber-500/10 transition"
                data-action="click->demo-modal#open"
                data-demo-modal-url="<%= library_match.youtube_embed_url %>"
                data-demo-title="<%= h exercise_name %>">
                Watch demo
              </button>
            <% end %>
          </div>
        </div>
        <div class="mt-3 sm:hidden">
          <details class="rounded-lg border border-slate-800 bg-slate-900/60 p-3">
            <summary class="cursor-pointer text-xs uppercase tracking-wide text-slate-400">Actions</summary>
            <div class="mt-3 grid gap-2">
              <button type="button"
                class="min-h-11 w-full rounded-md border border-slate-700 px-3 py-2 text-sm text-slate-200 hover:border-slate-500 transition text-left"
                data-action="click->session-exercises#edit">
                Edit
              </button>
              <button type="button"
                class="min-h-11 w-full rounded-md border border-slate-700 px-3 py-2 text-sm text-slate-200 hover:border-slate-500 transition text-left"
                data-action="click->session-exercises#swap">
                Swap
              </button>
              <button type="button"
                class="min-h-11 w-full rounded-md border border-rose-500/50 px-3 py-2 text-sm text-rose-200 hover:border-rose-400 transition text-left"
                data-action="click->session-exercises#remove">
                Remove
              </button>
              <% if library_match %>
                <button type="button"
                  class="min-h-11 w-full rounded-md border border-amber-400/40 px-3 py-2 text-sm text-amber-300 hover:bg-amber-500/10 transition text-left"
                  data-action="click->demo-modal#open"
                  data-demo-modal-url="<%= library_match.youtube_embed_url %>"
                  data-demo-title="<%= h exercise_name %>">
                  Watch demo
                </button>
              <% end %>
            </div>
          </details>
        </div>
        <% exercise_guidance = exercise["description"].presence || exercise["notes"].presence %>
        <% if exercise_guidance.present? %>
          <div class="text-sm text-slate-400 mb-3"><%= exercise_guidance %></div>
        <% end %>

        <!-- Set rows -->
        <div class="space-y-2">
          <% num_sets.times do |set_idx| %>
            <% set_key = "#{index}_#{set_idx}" %>
            <% set_log = (@planned_session.exercise_logs.find { |l| l["set_key"] == set_key }) || {} %>
            <% set_done = set_log["completed"] %>
            <div class="flex flex-wrap items-center gap-3 rounded-lg px-3 py-3 transition <%= set_done ? 'bg-green-500/5 border border-green-500/20' : 'bg-slate-800/40 border border-slate-800' %>"
                 data-set-key="<%= set_key %>"
                 data-exercise-index="<%= index %>"
                 data-set-index="<%= set_idx %>">
              <!-- Checkbox -->
              <label class="flex-shrink-0">
                <input
                  type="checkbox"
                  class="h-6 w-6 rounded border-slate-700 bg-slate-900 text-emerald-400"
                  <%= "checked" if set_done %>
                  data-action="change->exercise-log#queueSave"
                  data-set-key="<%= set_key %>"
                />
              </label>
              <!-- Set info -->
              <div class="flex-1 text-sm min-w-[180px]">
                <% if num_sets > 1 %>
                  <span class="text-slate-300"><%= set_done ? "✓" : "" %> Set <%= set_idx + 1 %> of <%= num_sets %></span>
                  <% if target_reps.present? %>
                    <% display_unit = rep_unit.to_s %>
                    <% if target_reps.to_s == "1" && display_unit.end_with?("s") && !display_unit.end_with?("ss") %>
                      <% display_unit = display_unit.chomp("s") %>
                    <% end %>
                    <span class="text-slate-500"> · <%= target_reps %> <%= display_unit %></span>
                  <% end %>
                <% else %>
                  <span class="text-slate-300 <%= set_done ? 'line-through text-slate-500' : '' %>"><%= prescribed_bits.any? ? prescribed_bits.join(" · ") : "Complete" %></span>
                <% end %>
                <% if target_grade.present? %>
                  <span class="inline-flex items-center rounded-full bg-amber-500/15 border border-amber-500/30 px-2 py-0.5 text-xs font-medium text-amber-300 ml-2"><%= target_grade %></span>
                <% end %>
              </div>
              <% input_placeholder = target_reps.present? ? target_reps.to_s : "" %>
              <% input_unit_label = rep_unit == "reps" ? "reps" : rep_unit %>
              <div class="flex items-center gap-2 text-xs text-slate-400">
                <div class="flex items-center gap-1">
                  <input
                    type="number"
                    inputmode="numeric"
                    class="h-8 w-16 rounded-md border border-slate-700 bg-slate-950 px-2 text-sm text-slate-100"
                    placeholder="<%= input_placeholder %>"
                    value="<%= set_log["actual_reps"] %>"
                    data-action="input->exercise-log#queueSave change->exercise-log#queueSave"
                    data-set-key="<%= set_key %>"
                    data-set-field="actual_reps"
                    data-recommended-value="<%= input_placeholder %>"
                  />
                  <span><%= input_unit_label %></span>
                </div>
                <% if show_weight %>
                  <div class="flex items-center gap-1">
                    <input
                      type="number"
                      inputmode="decimal"
                      step="0.5"
                      class="h-8 w-20 rounded-md border border-slate-700 bg-slate-950 px-2 text-sm text-slate-100"
                      placeholder="<%= recommended_weight %>"
                      value="<%= set_log["actual_weight"] %>"
                      data-action="input->exercise-log#queueSave change->exercise-log#queueSave"
                      data-set-key="<%= set_key %>"
                      data-set-field="actual_weight"
                      data-recommended-value="<%= recommended_weight %>"
                    />
                    <span>wt</span>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <% if work_seconds.present? || rest_seconds.present? %>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            <% if work_seconds.present? %>
              <% work_minutes = work_seconds / 60 %>
              <% work_remaining = work_seconds % 60 %>
              <details class="rounded-lg border border-slate-800 bg-slate-800/40 [&[open]_svg.timer-chevron]:rotate-90" data-controller="countdown-timer" data-countdown-timer-target="container">
                <summary class="cursor-pointer select-none list-none flex items-center justify-between p-3">
                  <div class="flex items-center gap-2">
                    <svg width="12" height="12" class="transition-transform timer-chevron text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                    <span class="text-xs uppercase tracking-wide text-slate-400">Work Timer</span>
                  </div>
                  <span class="text-[11px] text-slate-500"><%= exercise["duration"].presence || "#{work_minutes}m #{work_remaining}s" %></span>
                </summary>
                <div class="px-3 pb-3">
                <div class="mt-2 grid grid-cols-2 gap-2 text-xs text-slate-400" data-countdown-timer-target="inputWrapper">
                  <label class="flex items-center gap-2">
                    <input type="number" min="0" inputmode="numeric" class="h-11 w-full rounded-md border border-slate-700 bg-slate-950 px-2 text-base text-slate-100" value="<%= work_minutes %>" data-countdown-timer-target="minutes" />
                    <span class="shrink-0">min</span>
                  </label>
                  <label class="flex items-center gap-2">
                    <input type="number" min="0" max="59" inputmode="numeric" class="h-11 w-full rounded-md border border-slate-700 bg-slate-950 px-2 text-base text-slate-100" value="<%= work_remaining %>" data-countdown-timer-target="seconds" />
                    <span class="shrink-0">sec</span>
                  </label>
                </div>
                <div class="mt-3 text-3xl sm:text-4xl font-mono text-amber-400 text-center" style="display:none" data-countdown-timer-target="displayWrapper">
                  <div data-countdown-timer-target="display">0:00</div>
                </div>
                <div class="mt-3 flex gap-2">
                  <button type="button" class="w-full min-h-11 inline-flex items-center justify-center rounded-md border border-amber-500/40 px-3 py-2 text-sm font-semibold text-amber-200 hover:bg-amber-500/10 transition" data-action="countdown-timer#start" data-countdown-timer-target="startButton">
                    Start
                  </button>
                  <button type="button" class="w-full min-h-11 inline-flex items-center justify-center rounded-md border border-amber-500/40 px-3 py-2 text-sm font-semibold text-amber-200 hover:bg-amber-500/10 transition" style="display:none" data-action="countdown-timer#stop" data-countdown-timer-target="stopButton">
                    Stop
                  </button>
                  <button type="button" class="w-full min-h-11 inline-flex items-center justify-center rounded-md border border-slate-600/60 px-3 py-2 text-sm font-semibold text-slate-200 hover:border-slate-400 transition" style="display:none" data-action="countdown-timer#reset" data-countdown-timer-target="resetButton">
                    Reset
                  </button>
                </div>
                </div>
              </details>
            <% end %>
            <% if rest_seconds.present? %>
              <% rest_minutes = rest_seconds / 60 %>
              <% rest_remaining = rest_seconds % 60 %>
              <details class="rounded-lg border border-slate-800 bg-slate-800/40 [&[open]_svg.timer-chevron]:rotate-90" data-controller="countdown-timer" data-countdown-timer-target="container">
                <summary class="cursor-pointer select-none list-none flex items-center justify-between p-3">
                  <div class="flex items-center gap-2">
                    <svg width="12" height="12" class="transition-transform timer-chevron text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                    <span class="text-xs uppercase tracking-wide text-slate-400">Rest Timer</span>
                  </div>
                  <span class="text-[11px] text-slate-500"><%= exercise["rest"].presence || "#{rest_minutes}m #{rest_remaining}s" %></span>
                </summary>
                <div class="px-3 pb-3">
                <div class="mt-2 grid grid-cols-2 gap-2 text-xs text-slate-400" data-countdown-timer-target="inputWrapper">
                  <label class="flex items-center gap-2">
                    <input type="number" min="0" inputmode="numeric" class="h-11 w-full rounded-md border border-slate-700 bg-slate-950 px-2 text-base text-slate-100" value="<%= rest_minutes %>" data-countdown-timer-target="minutes" />
                    <span class="shrink-0">min</span>
                  </label>
                  <label class="flex items-center gap-2">
                    <input type="number" min="0" max="59" inputmode="numeric" class="h-11 w-full rounded-md border border-slate-700 bg-slate-950 px-2 text-base text-slate-100" value="<%= rest_remaining %>" data-countdown-timer-target="seconds" />
                    <span class="shrink-0">sec</span>
                  </label>
                </div>
                <div class="mt-3 text-3xl sm:text-4xl font-mono text-amber-400 text-center" style="display:none" data-countdown-timer-target="displayWrapper">
                  <div data-countdown-timer-target="display">0:00</div>
                </div>
                <div class="mt-3 flex gap-2">
                  <button type="button" class="w-full min-h-11 inline-flex items-center justify-center rounded-md border border-amber-500/40 px-3 py-2 text-sm font-semibold text-amber-200 hover:bg-amber-500/10 transition" data-action="countdown-timer#start" data-countdown-timer-target="startButton">
                    Start
                  </button>
                  <button type="button" class="w-full min-h-11 inline-flex items-center justify-center rounded-md border border-amber-500/40 px-3 py-2 text-sm font-semibold text-amber-200 hover:bg-amber-500/10 transition" style="display:none" data-action="countdown-timer#stop" data-countdown-timer-target="stopButton">
                    Stop
                  </button>
                  <button type="button" class="w-full min-h-11 inline-flex items-center justify-center rounded-md border border-slate-600/60 px-3 py-2 text-sm font-semibold text-slate-200 hover:border-slate-400 transition" style="display:none" data-action="countdown-timer#reset" data-countdown-timer-target="resetButton">
                    Reset
                  </button>
                </div>
                </div>
              </details>
            <% end %>
          </div>
        <% end %>

        <!-- Expandable notes -->
        <div class="mt-3 pl-2">
          <div class="text-xs text-slate-400" data-controller="speech-input">
            <div class="flex items-center justify-between">
              <label for="exercise-notes-<%= index %>">Notes</label>
              <button type="button" class="text-[11px] uppercase tracking-wide text-slate-200 border border-slate-600/60 rounded-md px-2 py-1 hover:border-slate-400 transition" data-action="speech-input#toggle" data-speech-input-target="button">
                Voice
              </button>
            </div>
            <textarea id="exercise-notes-<%= index %>" rows="2" class="mt-1 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" data-action="blur->exercise-log#queueSave" data-exercise-log-field="notes" data-speech-input-target="input"><%= log["notes"] %></textarea>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-8 rounded-2xl border border-slate-800 bg-slate-900 p-4">
    <div class="flex items-center justify-between">
      <h3 class="text-sm font-semibold text-slate-200">Add Exercise</h3>
    </div>
    <div class="mt-3 flex flex-wrap gap-3">
      <button
        type="button"
        class="rounded-md border border-slate-700 px-3 py-2 text-sm text-slate-200 hover:border-slate-500 transition"
        data-action="session-exercises#addExercise"
      >
        Add
      </button>
    </div>
  </div>

  <div class="mt-10 bg-slate-900 border border-slate-800 rounded-2xl p-4">
    <h3 class="text-sm font-semibold text-slate-200">Post-Session</h3>
    <div data-controller="speech-input">
      <div class="flex items-center justify-between">
        <h4 class="text-sm font-semibold text-slate-200">Session Notes</h4>
        <button type="button" class="text-[11px] uppercase tracking-wide text-slate-200 border border-slate-600/60 rounded-md px-2 py-1 hover:border-slate-400 transition" data-action="speech-input#toggle" data-speech-input-target="button">
          Voice
        </button>
      </div>
      <textarea
        rows="4"
        class="mt-3 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100"
        data-exercise-log-target="sessionNotes"
        data-speech-input-target="input"
        data-action="blur->exercise-log#queueSave"
      ><%= @planned_session.session_notes %></textarea>
    </div>

    <div class="mt-6 grid gap-4">
      <label class="text-xs text-slate-400" data-controller="range-value">
        <div class="flex items-center justify-between">
          <span>RPE</span>
          <span class="text-slate-200" data-range-value-target="output"></span>
        </div>
        <p class="text-[11px] text-slate-500 mt-1">Rate of Perceived Exertion — how hard the session felt overall on a 1-10 scale.</p>
        <input
          type="range"
          min="1"
          max="10"
          value="<%= @planned_session.perceived_exertion || 6 %>"
          class="mt-2 w-full"
          data-range-value-target="input"
          data-exercise-log-target="perceivedExertion"
          data-action="input->range-value#update change->exercise-log#queueSave"
        />
        <div class="flex justify-between text-[10px] text-slate-500 mt-1"><span>Easy</span><span>Max effort</span></div>
      </label>
    </div>
  </div>

  <div class="mt-8 grid gap-3 sm:flex sm:flex-wrap">
    <%= button_tag "Complete Session",
      type: "button",
      class: "w-full sm:w-auto min-h-11 bg-emerald-400 text-slate-950 px-4 py-2 rounded-md font-semibold hover:bg-emerald-300 active:bg-emerald-500 transition #{@planned_session.in_progress? ? "" : "hidden"}",
      data: { action: "session-completion#complete", session_completion_target: "completeButton" } %>
  </div>

  <div class="fixed inset-0 z-50 hidden bg-slate-950/80 p-4 backdrop-blur flex items-center justify-center" data-session-exercises-target="modal" data-action="click->session-exercises#closeOnBackdrop keydown@window->session-exercises#handleKeydown">
    <div class="w-full max-w-2xl max-h-[90vh] rounded-2xl border border-slate-800 bg-slate-900 shadow-xl overflow-hidden flex flex-col">
      <div class="flex items-center justify-between px-4 py-3 border-b border-slate-800">
        <div class="text-sm font-semibold text-slate-200" data-session-exercises-target="modalTitle">Edit Exercise</div>
        <button type="button" class="text-slate-400 hover:text-slate-100 transition" data-action="session-exercises#close" aria-label="Close">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="min-h-0 flex-1 overflow-y-auto p-4 space-y-4">
        <div class="hidden rounded-md border border-rose-500/40 bg-rose-500/10 px-3 py-2 text-sm text-rose-100" data-session-exercises-target="error"></div>

        <div data-session-exercises-target="editPanel">
          <form class="space-y-3" data-action="submit->session-exercises#saveForm">
            <div>
              <label class="text-xs uppercase tracking-wide text-slate-400">Name</label>
              <input type="text" class="mt-1 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" data-session-exercises-target="name" data-action="input->session-exercises#handleNameInput" />
              <div class="mt-2 rounded-lg border border-slate-800 bg-slate-950/60">
                <div class="px-3 py-2 text-xs text-slate-500" data-session-exercises-target="nameHint">Start typing to see matches.</div>
                <div class="divide-y divide-slate-800 max-h-40 overflow-auto" data-session-exercises-target="nameSuggestions"></div>
              </div>
            </div>
            <div class="grid gap-3 sm:grid-cols-2">
              <div>
                <label class="text-xs uppercase tracking-wide text-slate-400">Sets</label>
                <input type="text" class="mt-1 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" data-session-exercises-target="sets" />
              </div>
              <div>
                <label class="text-xs uppercase tracking-wide text-slate-400">Target Reps</label>
                <input type="text" class="mt-1 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" data-session-exercises-target="targetReps" placeholder="e.g. 10" />
              </div>
              <div>
                <label class="text-xs uppercase tracking-wide text-slate-400">Rep Unit</label>
                <select class="mt-1 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" data-session-exercises-target="repUnit">
                  <option value="reps">reps</option>
                  <option value="seconds">seconds</option>
                  <option value="minutes">minutes</option>
                  <option value="problems">problems</option>
                  <option value="routes">routes</option>
                  <option value="attempts">attempts</option>
                </select>
              </div>
              <div>
                <label class="text-xs uppercase tracking-wide text-slate-400">Target Grade</label>
                <input type="text" class="mt-1 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" data-session-exercises-target="targetGrade" placeholder="e.g. V2-V3" />
              </div>
              <div>
                <label class="text-xs uppercase tracking-wide text-slate-400">Target Weight</label>
                <input type="text" class="mt-1 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" data-session-exercises-target="targetWeight" placeholder="e.g. 25 lbs" />
              </div>
              <div>
                <label class="text-xs uppercase tracking-wide text-slate-400">Duration</label>
                <input type="text" class="mt-1 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" placeholder="e.g. 45 sec" data-session-exercises-target="duration" />
              </div>
              <div>
                <label class="text-xs uppercase tracking-wide text-slate-400">Rest</label>
                <input type="text" class="mt-1 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" placeholder="e.g. 2 min" data-session-exercises-target="rest" />
              </div>
            </div>
            <div>
              <label class="text-xs uppercase tracking-wide text-slate-400">Description</label>
              <textarea rows="2" class="mt-1 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" data-session-exercises-target="description"></textarea>
            </div>
            <div>
              <label class="text-xs uppercase tracking-wide text-slate-400">Notes</label>
              <textarea rows="2" class="mt-1 w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" data-session-exercises-target="notes"></textarea>
            </div>
            <div class="flex items-center justify-end gap-2 pt-2">
              <button type="button" class="rounded-md border border-slate-700 px-3 py-2 text-sm text-slate-200 hover:border-slate-500 transition" data-action="session-exercises#close">Cancel</button>
              <button type="submit" class="rounded-md bg-amber-500 px-3 py-2 text-sm font-semibold text-slate-950 hover:bg-amber-400 transition">Save</button>
            </div>
          </form>
        </div>

        <div class="hidden space-y-4" data-session-exercises-target="libraryPanel">
          <div class="space-y-2">
            <label class="text-xs uppercase tracking-wide text-slate-400">Search library</label>
            <input type="text" placeholder="Start typing an exercise..." autocomplete="off" class="w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-100" data-session-exercises-target="librarySearch" data-action="input->session-exercises#filterLibrary" />
            <div class="rounded-lg border border-slate-800 bg-slate-950/60">
              <div class="px-3 py-2 text-xs text-slate-500" data-session-exercises-target="libraryHint">Start typing to see matches.</div>
              <div class="divide-y divide-slate-800 max-h-56 overflow-auto" data-session-exercises-target="librarySuggestions"></div>
            </div>
          </div>

          <div class="flex flex-wrap items-center justify-between gap-3">
            <label class="flex items-center gap-2 text-xs text-slate-400" data-session-exercises-target="keepPrescriptionWrapper">
              <input type="checkbox" class="h-4 w-4 rounded border-slate-700 bg-slate-950 text-amber-400" checked data-session-exercises-target="keepPrescription" />
              Keep existing prescription (sets/reps/duration/rest)
            </label>
            <button type="button" class="text-xs text-slate-400 hover:text-slate-200 transition" data-session-exercises-target="libraryBrowseToggle" data-action="session-exercises#toggleBrowse">
              Browse all
            </button>
          </div>

          <div class="hidden space-y-2" data-session-exercises-target="libraryBrowse">
            <div class="text-xs uppercase tracking-wide text-slate-500">Browse library</div>
            <div class="max-h-56 space-y-2 overflow-auto pr-1" data-session-exercises-target="libraryList"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="fixed inset-0 z-50 hidden bg-slate-950/80 p-4 backdrop-blur flex items-center justify-center" data-demo-modal-target="modal" data-action="click->demo-modal#closeOnBackdrop keydown@window->demo-modal#handleKeydown">
    <div class="w-full max-w-3xl rounded-2xl border border-slate-800 bg-slate-900 shadow-xl overflow-hidden">
      <div class="flex items-center justify-between px-4 py-3 border-b border-slate-800">
        <div class="text-sm font-semibold text-slate-200" data-demo-modal-target="title">Exercise Demo</div>
        <button type="button" class="text-slate-400 hover:text-slate-100 transition" data-action="demo-modal#close" aria-label="Close">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="relative w-full" style="padding-top: 56.25%">
        <iframe class="absolute inset-0 w-full h-full" title="Exercise demo" allow="autoplay; encrypted-media" allowfullscreen data-demo-modal-target="frame"></iframe>
      </div>
    </div>
  </div>
</div>
