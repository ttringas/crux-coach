<div class="max-w-4xl mx-auto">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-slate-100">Benchmarks</h1>
    <p class="mt-1 text-sm text-slate-400">Track your climbing performance metrics. These feed into your AI-generated training plans.</p>
  </div>

  <div class="space-y-4">
    <% @grouped_benchmarks.each do |category, benchmarks| %>
      <% has_values = benchmarks.any? { |b| b.value.present? } %>
      <details class="group bg-slate-900 border border-slate-800 rounded-xl overflow-hidden" <%= "open" if has_values %>>
        <summary class="flex items-center justify-between px-5 py-4 cursor-pointer hover:bg-slate-800/50 transition">
          <div class="flex items-center gap-3">
            <h2 class="text-base font-semibold text-slate-100"><%= category %></h2>
            <span class="text-xs text-slate-500">
              <%= benchmarks.count { |b| b.value.present? } %>/<%= benchmarks.size %> tracked
            </span>
          </div>
          <svg class="w-4 h-4 text-slate-500 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>

        <div class="border-t border-slate-800">
          <% benchmarks.each do |benchmark| %>
            <% definition = ClimbingBenchmark::DEFINITIONS_BY_KEY[benchmark.benchmark_key] %>
            <%= render "benchmarks/benchmark_row", benchmark: benchmark, definition: definition %>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>
</div>
