<% prev_month = @month_start.prev_month %>
<% next_month = @month_start.next_month %>

<div class="flex items-center gap-3 mb-4">
  <%= link_to "←", calendar_path(view: "monthly", month: prev_month.strftime("%Y-%m")), class: "flex h-9 w-9 items-center justify-center rounded-md border border-slate-700 text-slate-300 hover:border-slate-500 hover:text-slate-100 transition" %>
  <h2 class="text-lg font-semibold"><%= @month_start.strftime("%B %Y") %></h2>
  <%= link_to "→", calendar_path(view: "monthly", month: next_month.strftime("%Y-%m")), class: "flex h-9 w-9 items-center justify-center rounded-md border border-slate-700 text-slate-300 hover:border-slate-500 hover:text-slate-100 transition" %>
</div>

<% mobile_dates = @calendar_dates.select { |date| date.month == @month_start.month } %>
<% mobile_days_with_sessions = mobile_dates.select { |date| (@sessions_by_date[date] || []).any? } %>
<div class="sm:hidden space-y-3">
  <% if mobile_days_with_sessions.any? %>
    <% mobile_days_with_sessions.each do |date| %>
      <% sessions = @sessions_by_date[date] || [] %>
      <div class="rounded-2xl border border-slate-800 bg-slate-900 p-4">
        <div class="flex items-center justify-between">
          <div class="text-sm font-semibold text-slate-200"><%= date.strftime("%a, %b %d") %></div>
          <% if date == Date.current %>
            <span class="text-xs uppercase tracking-wide text-amber-400">Today</span>
          <% end %>
        </div>
        <div class="mt-3 space-y-2">
          <% sessions.each do |session| %>
            <% status_color = case session.status
              when "completed" then "text-emerald-300"
              when "in_progress" then "text-amber-300"
              when "skipped" then "text-slate-500"
              else "text-slate-300"
            end %>
            <%= link_to weekly_plan_planned_session_path(session.weekly_plan, session), class: "block rounded-xl border border-slate-800 bg-slate-900/70 p-3 hover:border-slate-600 transition" do %>
              <div class="flex items-center justify-between gap-2">
                <div class="text-xs uppercase tracking-wide <%= status_color %>"><%= session.session_type %> · <%= session.intensity&.humanize %></div>
                <div class="text-xs text-slate-400"><%= session.estimated_duration_minutes || "-" %>m</div>
              </div>
              <div class="mt-1 text-sm font-semibold text-slate-100"><%= session.title %></div>
              <% if session.description.present? %>
                <div class="mt-1 text-xs text-slate-400"><%= session.description.truncate(80) %></div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="rounded-2xl border border-slate-800 bg-slate-900 p-6 text-center text-slate-300">
      <div class="text-base font-semibold text-slate-100">No sessions scheduled this month.</div>
      <div class="mt-2 text-sm text-slate-400">Generate a training block to populate the calendar.</div>
    </div>
  <% end %>
</div>

<div class="hidden sm:block bg-slate-900 border border-slate-800 rounded-2xl p-4 overflow-x-auto" data-controller="monthly-drag">
  <!-- Day headers -->
  <div class="grid grid-cols-7 gap-1 mb-2">
    <% %w[Mon Tue Wed Thu Fri Sat Sun].each do |day| %>
      <div class="text-xs text-slate-400 text-center font-medium py-1"><%= day %></div>
    <% end %>
  </div>

  <!-- Calendar grid -->
  <div class="grid grid-cols-7 gap-1">
    <% @calendar_dates.each do |date| %>
      <% is_today = date == Date.current %>
      <% in_month = date.month == @month_start.month %>
      <% sessions = @sessions_by_date[date] || [] %>

      <div class="min-h-[160px] rounded-lg border p-2 transition
        <%= is_today ? 'border-amber-500/50 bg-amber-500/5' : in_month ? 'border-slate-800 bg-slate-900/50' : 'border-slate-800/50 bg-slate-950/50' %>"
        data-monthly-drag-target="dayCell"
        data-date="<%= date.to_s %>"
        data-day-of-week="<%= (date.wday + 6) % 7 %>">

        <div class="text-xs font-medium mb-1.5 <%= is_today ? 'text-amber-400' : in_month ? 'text-slate-300' : 'text-slate-600' %>">
          <%= date.day %>
        </div>

        <div class="space-y-1.5 min-h-[100px]" data-monthly-drag-target="sessionList">
          <% sessions.each do |session| %>
            <% colors = "bg-slate-800/60 text-slate-300 border-slate-700" %>
            <div class="rounded-md border p-1.5 cursor-grab select-none <%= colors %> <%= session.completed? ? 'line-through opacity-60' : '' %>"
              draggable="true"
              data-monthly-drag-target="session"
              data-session-id="<%= session.id %>"
              data-update-url="<%= weekly_plan_planned_session_path(session.weekly_plan, session) %>"
              data-session-title="<%= session.title %>"
              data-session-type="<%= session.session_type %>"
              data-session-intensity="<%= session.intensity&.humanize %>"
              data-session-duration="<%= session.estimated_duration_minutes %>"
              data-session-description="<%= session.description&.truncate(300) %>"
              data-session-status="<%= session.status %>"
              data-session-url="<%= weekly_plan_planned_session_path(session.weekly_plan, session) %>"
              data-action="click->monthly-drag#showSessionDetail">
              <div class="text-xs font-semibold leading-tight"><%= session.title %></div>
              <% if session.estimated_duration_minutes %>
                <div class="text-[10px] opacity-70 mt-0.5"><%= session.estimated_duration_minutes %>min</div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
