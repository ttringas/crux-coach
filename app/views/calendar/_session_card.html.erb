<% status = session.status || "todo" %>
<% status_classes = case status
  when "completed" then "border-green-500/30 bg-green-500/5"
  when "in_progress" then "border-amber-500/30 bg-amber-500/5"
  when "skipped" then "border-slate-600/60 bg-slate-800/60"
  else "border-slate-700 bg-slate-900"
end %>
<div class="rounded-lg border p-3 transition hover:border-slate-500 select-none cursor-pointer sm:cursor-grab <%= status_classes %>"
     data-plan-drag-target="session"
     data-session-id="<%= session.id %>"
     data-update-url="<%= weekly_plan_planned_session_path(weekly_plan, session) %>"
     data-day-index="<%= session.day_of_week %>"
     data-position="<%= session.position || 0 %>"
     data-session-title="<%= session.title %>"
     data-session-type="<%= session.session_type %>"
     data-session-intensity="<%= session.intensity %>"
     data-session-duration="<%= session.estimated_duration_minutes %>"
     data-session-description="<%= session.description&.truncate(200) %>"
     data-session-url="<%= weekly_plan_planned_session_path(weekly_plan, session) %>"
     draggable="true">
  <div class="flex items-center justify-between gap-2">
    <div class="flex items-center gap-2 min-w-0">
      <% if status == "completed" %>
        <span class="shrink-0 h-4 w-4 rounded-full border border-green-400 text-green-300 flex items-center justify-center text-[10px]">✓</span>
      <% elsif status == "in_progress" %>
        <span class="shrink-0 h-3 w-3 rounded-full border-2 border-amber-400 border-t-transparent animate-spin"></span>
      <% else %>
        <span class="shrink-0 h-2 w-2 rounded-full bg-slate-500"></span>
      <% end %>
      <div class="min-w-0">
        <div class="text-xs text-slate-400 uppercase tracking-wide"><%= session.session_type %></div>
        <div class="text-sm text-slate-100 font-medium truncate"><%= session.title %></div>
      </div>
    </div>
    <div class="text-xs text-slate-400 shrink-0"><%= session.estimated_duration_minutes || "-" %>m</div>
  </div>
  <div class="mt-2 flex items-center justify-between">
    <% status_label = case status
      when "todo" then "Upcoming"
      when "in_progress" then "In Progress"
      when "completed" then "Completed"
      when "skipped" then "Skipped"
      else status.humanize
    end %>
    <span class="text-[10px] text-slate-500 uppercase"><%= session.intensity %> · <%= status_label %></span>
    <%= link_to "Go →", weekly_plan_planned_session_path(weekly_plan, session), class: "text-xs font-semibold text-amber-400 hover:text-amber-300 inline-flex items-center rounded-md px-2 py-1.5 hover:bg-amber-500/10 transition", data: { turbo: false } %>
  </div>
</div>
