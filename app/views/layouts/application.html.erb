<!DOCTYPE html>
<html>
  <head>
    <title>BKUP TRAIN</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-950 text-slate-100 min-h-screen">
    <div data-controller="mobile-nav" class="min-h-screen">
      <% if user_signed_in? && !@immersive_layout %>
        <div class="md:flex">
          <div class="fixed inset-0 bg-slate-950/80 z-30 hidden" data-mobile-nav-target="overlay" data-action="click->mobile-nav#close"></div>
          <aside class="fixed inset-y-0 left-0 w-60 bg-slate-900 border-r border-slate-800 z-40 transform -translate-x-full transition md:translate-x-0 md:static md:inset-auto" data-mobile-nav-target="sidebar">
            <div class="flex items-center justify-between px-6 py-5 border-b border-slate-800">
              <span class="text-lg font-semibold tracking-wide">BKUP TRAIN</span>
              <button class="md:hidden text-slate-300" data-action="click->mobile-nav#close">
                <span class="sr-only">Close</span>
                ✕
              </button>
            </div>
            <nav class="px-4 py-6 space-y-1 text-sm">
              <% if current_user.admin? %>
                <%= link_to dashboard_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800/70" do %>
                  <%= render "shared/nav_icon", name: "dashboard" %>
                  <span>Dashboard</span>
                <% end %>
              <% end %>
              <%= link_to training_blocks_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800/70" do %>
                <%= render "shared/nav_icon", name: "plan" %>
                <span>Plans</span>
              <% end %>
              <%= link_to calendar_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800/70" do %>
                <%= render "shared/nav_icon", name: "calendar" %>
                <span>Calendar</span>
              <% end %>
              <%= link_to exercise_library_entries_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800/70" do %>
                <%= render "shared/nav_icon", name: "video" %>
                <span>Library</span>
              <% end %>
              <%= link_to benchmarks_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800/70" do %>
                <%= render "shared/nav_icon", name: "benchmarks" %>
                <span>Benchmarks</span>
              <% end %>
              <% if current_user.admin? %>
                <%= link_to progress_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800/70" do %>
                  <%= render "shared/nav_icon", name: "progress" %>
                  <span>Progress</span>
                <% end %>
                <%= link_to coaches_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800/70" do %>
                  <%= render "shared/nav_icon", name: "coaches" %>
                  <span>Coaches</span>
                <% end %>
              <% end %>
              <%= link_to profile_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800/70" do %>
                <%= render "shared/nav_icon", name: "profile" %>
                <span>Profile</span>
              <% end %>
              <% if current_user.admin? %>
                <div class="pt-4 mt-4 border-t border-slate-800 text-xs uppercase tracking-wide text-slate-500">Admin</div>
                <%= link_to admin_plans_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800/70" do %>
                  <%= render "shared/nav_icon", name: "plan" %>
                  <span>Plans</span>
                <% end %>
                <%= link_to admin_ai_usage_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800/70" do %>
                  <%= render "shared/nav_icon", name: "progress" %>
                  <span>AI Usage</span>
                <% end %>
              <% end %>
            </nav>
            <div class="px-6 pb-6 text-sm border-t border-slate-800">
              <div class="pt-4 md:hidden">
                <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "w-full text-left text-amber-400 hover:text-amber-300" %>
              </div>
              <div class="pt-4 text-sm text-slate-400 font-medium tracking-wide leading-relaxed">
                <div>Made with ❤️ by</div>
                <div>
                  <%= link_to "Brooklyn Uprising", "https://bkup.nyc", class: "text-slate-100 hover:text-amber-200 underline decoration-amber-400/40 decoration-2 underline-offset-4 transition" %>
                </div>
              </div>
            </div>
          </aside>

          <div class="flex-1 min-h-screen">
            <header class="sticky top-0 z-20 bg-slate-950/80 backdrop-blur border-b border-slate-800">
              <div class="flex items-center justify-between px-4 md:px-8 py-4">
                <div class="flex items-center gap-3">
                  <button class="md:hidden text-slate-300 w-11 h-11 flex items-center justify-center rounded-lg hover:bg-slate-800/70 transition" data-action="click->mobile-nav#open">
                    <span class="sr-only">Open</span>
                    ☰
                  </button>
                  <span class="text-lg font-semibold tracking-wide">BKUP TRAIN</span>
                </div>
                <div class="hidden md:flex items-center gap-4 text-sm text-slate-200">
                  <span><%= current_user.name.presence || current_user.email %></span>
                  <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "text-amber-400 hover:text-amber-300" %>
                </div>
              </div>
            </header>

            <main class="px-4 md:px-6 py-6">
              <% if notice.present? %>
                <div class="mb-6 rounded-lg border border-amber-500/40 bg-amber-500/10 px-4 py-3 text-sm text-amber-200">
                  <%= notice %>
                </div>
              <% end %>
              <% if alert.present? %>
                <div class="mb-6 rounded-lg border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm text-red-200">
                  <%= alert %>
                </div>
              <% end %>

              <%= yield %>
            </main>
          </div>
        </div>
      <% elsif user_signed_in? %>
        <main class="min-h-screen">
          <% if notice.present? %>
            <div class="mb-6 rounded-lg border border-amber-500/40 bg-amber-500/10 px-4 py-3 text-sm text-amber-200">
              <%= notice %>
            </div>
          <% end %>
          <% if alert.present? %>
            <div class="mb-6 rounded-lg border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm text-red-200">
              <%= alert %>
            </div>
          <% end %>

          <%= yield %>
        </main>
      <% else %>
        <main>
          <%= yield %>
        </main>
        <footer class="text-center text-sm text-slate-400 py-8 font-medium tracking-wide leading-relaxed">
          <div>Made with ❤️ by</div>
          <div>
            <%= link_to "Brooklyn Uprising", "https://bkup.nyc", class: "text-slate-100 hover:text-amber-200 underline decoration-amber-400/40 decoration-2 underline-offset-4 transition" %>
          </div>
        </footer>
      <% end %>
    </div>
  </body>
</html>
