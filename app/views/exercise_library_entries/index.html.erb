<div class="flex flex-wrap items-end justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-semibold">Exercise Library</h1>
    <p class="text-sm text-slate-400">Browse demo videos and coaching notes for key exercises.</p>
  </div>
  <form action="<%= exercise_library_entries_path %>" method="get" class="w-full md:w-auto">
    <div class="flex items-center gap-2 rounded-xl border border-slate-800 bg-slate-900 px-3 py-2">
      <input
        type="text"
        name="q"
        value="<%= @query %>"
        placeholder="Search by name, channel, or tags"
        class="w-full md:w-72 bg-transparent text-sm text-slate-200 placeholder:text-slate-500 focus:outline-none"
      />
      <% if @category.present? && @category != "all" %>
        <input type="hidden" name="category" value="<%= @category %>" />
      <% end %>
      <button type="submit" class="text-xs text-amber-300 hover:text-amber-200">Search</button>
    </div>
  </form>
</div>

<div class="flex flex-wrap gap-2 mb-6">
  <% @categories.each do |category| %>
    <% active = (@category == category) %>
    <%= link_to exercise_library_entries_path(category: (category == "all" ? nil : category), q: @query.presence),
      class: "px-3 py-1 rounded-full text-xs border transition #{active ? 'bg-amber-500/20 text-amber-200 border-amber-400/40' : 'bg-slate-900 text-slate-300 border-slate-800 hover:border-slate-600'}" do %>
      <%= category.humanize %>
    <% end %>
  <% end %>
</div>

<div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
  <% @entries.each do |entry| %>
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-5 flex flex-col gap-4">
      <div class="flex items-start justify-between gap-3">
        <div>
          <div class="text-xs uppercase tracking-wide text-slate-500"><%= entry.category.humanize %></div>
          <h2 class="text-lg font-semibold mt-1"><%= entry.name %></h2>
          <p class="text-sm text-slate-400 mt-1"><%= entry.video_title %></p>
          <div class="text-xs text-slate-500 mt-1"><%= entry.channel_name %></div>
        </div>
        <%= link_to "Open", exercise_library_entry_path(entry), class: "text-xs text-amber-300 hover:text-amber-200" %>
      </div>

      <% if entry.description.present? %>
        <p class="text-sm text-slate-300"><%= entry.description %></p>
      <% end %>

      <div class="flex flex-wrap gap-2">
        <% entry.display_tags.each do |tag| %>
          <span class="px-2 py-1 rounded-full bg-slate-800 text-xs text-slate-200 border border-slate-700"><%= tag %></span>
        <% end %>
        <% if entry.duration_estimate.present? %>
          <span class="px-2 py-1 rounded-full bg-slate-800 text-xs text-slate-200 border border-slate-700"><%= entry.duration_estimate %></span>
        <% end %>
      </div>

      <details class="rounded-xl border border-slate-800 bg-slate-950/60 p-3">
        <summary class="cursor-pointer text-xs text-amber-300">Preview video</summary>
        <div class="mt-3 aspect-video overflow-hidden rounded-lg border border-slate-800">
          <iframe
            src="<%= entry.youtube_embed_url %>"
            title="<%= entry.video_title %>"
            class="w-full h-full"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </details>
    </div>
  <% end %>
</div>

<% if @entries.empty? %>
  <div class="mt-10 text-sm text-slate-400">No exercises found. Try a different search.</div>
<% end %>
