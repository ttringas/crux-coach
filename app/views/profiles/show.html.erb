<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Profile</h1>
      <p class="text-slate-400 text-sm">Edit your training preferences anytime.</p>
    </div>
    <%= link_to "Edit", edit_profile_path, class: "text-amber-400" %>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 text-sm text-slate-300">
      <div class="text-amber-400 text-xs uppercase">Basics</div>
      <div class="mt-2">Name: <span class="text-slate-100"><%= current_user.name.presence || "-" %></span></div>
      <div>Years climbing: <span class="text-slate-100"><%= @profile.years_climbing || "-" %></span></div>
      <div>Max boulder: <span class="text-slate-100"><%= @profile.current_max_boulder_grade || "-" %></span></div>
      <div>Max sport: <span class="text-slate-100"><%= @profile.current_max_sport_grade || "-" %></span></div>
    </div>
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 text-sm text-slate-300">
      <div class="text-amber-400 text-xs uppercase">Schedule</div>
      <div class="mt-2">Training days: <span class="text-slate-100"><%= @profile.weekly_training_days || "-" %></span></div>
      <div>Session duration: <span class="text-slate-100"><%= @profile.session_duration_minutes || "-" %> min</span></div>
      <div>Equipment: <span class="text-slate-100"><%= @profile.available_equipment.join(", ").presence || "-" %></span></div>
    </div>
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 text-sm text-slate-300">
      <div class="text-amber-400 text-xs uppercase">Goals</div>
      <div class="mt-2"><%= @profile.goals_short_term.presence || "No short-term goals yet." %></div>
      <div class="mt-2"><%= @profile.goals_long_term.presence || "No long-term goals yet." %></div>
    </div>
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 text-sm text-slate-300">
      <div class="text-amber-400 text-xs uppercase">Style</div>
      <div class="mt-2">Strengths: <span class="text-slate-100"><%= @profile.style_strengths.join(", ").presence || "-" %></span></div>
      <div>Weaknesses: <span class="text-slate-100"><%= @profile.style_weaknesses.join(", ").presence || "-" %></span></div>
    </div>
  </div>
</div>
