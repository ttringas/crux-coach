<div id="<%= dom_id(profile, :training_block_generation) %>">
  <div class="rounded-2xl border border-amber-500/30 bg-slate-950/40 p-5" data-block-generator-target="pending">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <div class="text-xs uppercase tracking-[0.2em] text-amber-300/80">Training block generation</div>
        <div class="text-lg font-semibold text-slate-100 mt-2">Coach is building your full block</div>
        <div class="text-xs text-slate-400 mt-2" data-block-generator-target="statusMessage">
          Preparing your season arc and training focus…
        </div>
      </div>
      <div class="text-sm text-amber-200 font-semibold" data-block-generator-target="progressLabel">6%</div>
    </div>
    <div class="mt-4 h-2 w-full rounded-full bg-slate-800/80 overflow-hidden">
      <div
        class="h-full rounded-full bg-gradient-to-r from-amber-400 via-amber-300 to-emerald-300 transition-[width] duration-500"
        style="width: 6%;"
        data-block-generator-target="progressFill"></div>
    </div>
    <div class="mt-3 text-xs text-slate-400">We’ll update this automatically when it’s ready. If it takes too long, the page will refresh to check again.</div>
  </div>
</div>
