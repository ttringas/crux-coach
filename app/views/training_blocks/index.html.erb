<style>details[open] > summary svg.details-chevron { transform: rotate(90deg); }</style>
<div class="flex flex-col gap-6" data-controller="block-generator regenerate-modal session-modal">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <h1 class="text-2xl font-semibold">Training Plans</h1>
  </div>

  <!-- Generate New Block Form (always visible at top) -->
  <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6">
    <details <%= @active_blocks.empty? ? 'open' : '' %>>
      <summary class="cursor-pointer select-none list-none flex items-center justify-between">
        <h3 class="text-lg font-semibold flex items-center gap-2">
          <svg width="14" height="14" class="transition-transform details-chevron text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          Generate New Training Block
        </h3>
        <span class="bg-amber-500 text-slate-950 text-xs font-bold px-2 py-1 rounded-full">+ New</span>
      </summary>
      <div class="mt-4">
        <% if @training_block&.active? %>
          <p class="text-sm text-slate-400 mb-4">You have an active block. Creating a new one will run alongside it.</p>
        <% end %>
        <%= form_with url: training_blocks_path, method: :post, data: { controller: "block-generator", turbo: false }, class: "space-y-4" do %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-slate-300 mb-1">Start Date</label>
              <input type="date" name="start_date" value="<%= Date.current.beginning_of_week(:monday).to_s %>"
                class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-sm text-slate-100 focus:outline-none focus:border-amber-500"
                data-block-generator-target="startDate">
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-300 mb-1">End Date</label>
              <input type="date" name="end_date" value="<%= (Date.current.beginning_of_week(:monday) + 6.weeks).to_s %>"
                class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-sm text-slate-100 focus:outline-none focus:border-amber-500"
                data-block-generator-target="endDate">
            </div>
          </div>
          <!-- Training Days -->
          <div>
            <label class="block text-sm font-medium text-slate-300 mb-2">Training Days</label>
            <div class="flex flex-wrap gap-2">
              <% %w[Monday Tuesday Wednesday Thursday Friday Saturday Sunday].each do |day| %>
                <label class="flex items-center gap-1.5 bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 cursor-pointer hover:border-amber-500/50 has-[:checked]:border-amber-500 has-[:checked]:bg-amber-500/10 transition">
                  <input type="checkbox" name="training_days[]" value="<%= day %>"
                    class="h-3.5 w-3.5 rounded border-slate-600 bg-slate-700 text-amber-500 focus:ring-amber-500 focus:ring-offset-0 accent-amber-500"
                    <%= %w[Monday Tuesday Wednesday Thursday Friday].include?(day) ? 'checked' : '' %>>
                  <span class="text-sm text-slate-300 select-none"><%= day[0..2] %></span>
                </label>
              <% end %>
            </div>
          </div>

          <!-- Activity Preferences -->
          <div>
            <label class="block text-sm font-medium text-slate-300 mb-2">Activities to Include</label>
            <div class="flex flex-wrap gap-2">
              <% { "Bouldering" => "🪨", "Rope climbing" => "🧗", "Board climbing" => "📋", "Hangboarding" => "🤏", "Strength training" => "💪", "Cardio" => "🏃", "Mobility" => "🧘" }.each do |activity, emoji| %>
                <label class="flex items-center gap-1.5 bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 cursor-pointer hover:border-amber-500/50 has-[:checked]:border-amber-500 has-[:checked]:bg-amber-500/10 transition">
                  <input type="checkbox" name="activities[]" value="<%= activity %>"
                    class="h-3.5 w-3.5 rounded border-slate-600 bg-slate-700 text-amber-500 focus:ring-amber-500 focus:ring-offset-0 accent-amber-500"
                    checked>
                  <span class="text-sm text-slate-300 select-none"><%= emoji %> <%= activity %></span>
                </label>
              <% end %>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-300 mb-1">Goals & Comments</label>
            <textarea name="comments" rows="3" placeholder="e.g. Training for a V8 project, want to improve finger strength and power endurance..."
              class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:border-amber-500"></textarea>
          </div>
          <div class="flex items-center gap-4">
            <button type="submit" class="bg-amber-500 text-slate-950 px-6 py-2 rounded-md font-semibold hover:bg-amber-400 active:bg-amber-600 transition"
              data-block-generator-target="button"
              data-action="click->block-generator#submit">
              Generate Training Block
            </button>
            <div class="hidden flex items-center gap-2 text-sm text-slate-300" data-block-generator-target="status">
              <span class="h-4 w-4 rounded-full border-2 border-amber-500 border-t-transparent animate-spin"></span>
              <span>Generating your training block... This may take up to a minute.</span>
            </div>
          </div>
        <% end %>
      </div>
    </details>
  </div>

  <% if @active_blocks.empty? && @completed_blocks.empty? %>
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8 text-center">
      <div class="text-lg font-semibold text-slate-100">No training blocks yet</div>
      <p class="mt-2 text-sm text-slate-400">Generate your first multi-week training plan above to get started.</p>
    </div>
  <% end %>

  <!-- Active Training Blocks -->
  <% @active_block_data.each do |data| %>
    <% block = data[:block] %>
    <% weekly_plans = data[:weekly_plans] %>
    <% current_week_index = data[:current_week_index] %>

    <div class="bg-slate-900 border border-amber-500/30 rounded-2xl p-6">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <div class="flex items-center gap-2">
            <span class="text-xs bg-green-500/20 text-green-300 px-2 py-0.5 rounded-full font-medium">Active</span>
            <span class="text-sm text-slate-400 uppercase tracking-wide"><%= block.focus.humanize %> Phase</span>
          </div>
          <h2 class="text-xl font-semibold mt-1"><%= block.name %></h2>
          <div class="flex items-center gap-4 mt-2 text-sm text-slate-400">
            <% end_date = block.ends_at || (block.started_at + block.weeks_planned.weeks if block.started_at && block.weeks_planned) %>
            <span><%= block.started_at&.strftime("%b %d") %> – <%= end_date&.strftime("%b %d, %Y") %></span>
            <span>·</span>
            <span><%= block.weeks_planned %> weeks</span>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <button type="button"
            class="bg-slate-800 text-slate-200 px-4 py-2 rounded-md text-sm font-medium hover:bg-slate-700 transition border border-slate-700"
            data-action="click->regenerate-modal#open"
            data-regenerate-modal-block-id-param="<%= block.id %>">
            Regenerate
          </button>
          <%= button_to "Complete Block", complete_training_block_path(block),
            method: :post,
            class: "bg-amber-500 text-slate-950 px-4 py-2 rounded-md text-sm font-semibold hover:bg-amber-400 transition",
            data: { turbo_confirm: "Complete this training block? Past progress will be saved but future sessions will be removed." } %>
        </div>
      </div>

      <% if block.overall_focus.present? %>
        <p class="mt-4 text-slate-300 text-sm"><%= block.overall_focus %></p>
      <% end %>

      <% if block.ai_reasoning.present? %>
        <p class="mt-2 text-slate-400 text-xs italic"><%= block.ai_reasoning %></p>
      <% end %>

      <!-- Progress Bar -->
      <% if block.weeks_planned && block.weeks_planned > 0 %>
        <div class="mt-6">
          <div class="flex items-center justify-between text-xs text-slate-400 mb-2">
            <span>Progress</span>
            <span>Week <%= (current_week_index || 0) + 1 %> of <%= block.weeks_planned %></span>
          </div>
          <div class="w-full bg-slate-800 rounded-full h-2">
            <div class="bg-amber-500 h-2 rounded-full transition-all" style="width: <%= [((current_week_index || 0) + 1).to_f / block.weeks_planned * 100, 100].min %>%"></div>
          </div>
        </div>
      <% end %>

      <!-- Week-by-Week Breakdown (expanded by default for active) -->
      <details open class="mt-6">
        <summary class="cursor-pointer select-none list-none flex items-center gap-2 text-sm font-semibold text-slate-300 hover:text-slate-100">
          <svg width="14" height="14" class="transition-transform details-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          Week-by-Week Overview
        </summary>
        <div class="mt-4 space-y-3">
          <% weekly_plans.each_with_index do |wp, index| %>
            <% is_current = index == current_week_index %>
            <% is_past = current_week_index && index < current_week_index %>
            <% is_placeholder = !wp.is_a?(WeeklyPlan) %>
            <% sessions = is_placeholder ? [] : wp.planned_sessions.sort_by { |s| [s.day_of_week, s.position || 0] } %>
            <% completed_count = sessions.count { |s| s.completed? } %>
            <% total_count = sessions.count { |s| !s.rest? } %>

            <div class="bg-slate-800/50 border rounded-xl p-4 transition
              <%= is_current ? 'border-amber-500/50 ring-1 ring-amber-500/20' : 'border-slate-700/50 hover:border-slate-600' %>">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <div class="flex items-center gap-3">
                  <div class="flex items-center justify-center w-7 h-7 rounded-full text-xs font-bold
                    <%= is_past ? 'bg-green-500/20 text-green-300' : is_current ? 'bg-amber-500/20 text-amber-300' : 'bg-slate-700 text-slate-400' %>">
                    <%= index + 1 %>
                  </div>
                  <div>
                    <div class="font-semibold text-sm">
                      Week <%= wp.week_number %> — <%= wp.week_of.strftime("%b %d") %>
                      <% if is_current %>
                        <span class="ml-2 text-xs bg-amber-500/20 text-amber-300 px-2 py-0.5 rounded-full">Current</span>
                      <% end %>
                    </div>
                    <div class="text-sm text-slate-400 mt-0.5">
                      <%= wp.week_focus.presence || wp.summary.presence || "Week #{wp.week_number}" %>
                    </div>
                  </div>
                </div>
                <div class="flex items-center gap-3 text-xs text-slate-400">
                  <% if is_placeholder %>
                    <span class="text-slate-500 italic">Not yet generated</span>
                  <% elsif total_count > 0 %>
                    <span><%= completed_count %>/<%= total_count %> sessions done</span>
                  <% end %>
                </div>
              </div>

              <% unless is_placeholder %>
                <details class="mt-3">
                  <summary class="cursor-pointer text-xs text-slate-400 hover:text-slate-300 select-none list-none flex items-center gap-1">
                    <svg width="14" height="14" class="transition-transform details-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                    <span><%= sessions.size %> session<%= sessions.size == 1 ? '' : 's' %></span>
                  </summary>
                  <div class="mt-2 flex flex-wrap gap-2">
                    <% sessions.each do |session| %>
                      <% day_abbrevs = %w[Mon Tue Wed Thu Fri Sat Sun] %>
                      <% if session.rest? %>
                        <span class="text-xs px-2 py-1 rounded-md border bg-slate-800/60 text-slate-300 border-slate-700
                          <%= session.completed? ? 'line-through opacity-60' : '' %>">
                          <span class="font-medium"><%= day_abbrevs[session.day_of_week] %></span>
                          <%= session.title %>
                          <% if session.completed? %>✓<% end %>
                        </span>
                      <% else %>
                        <button type="button"
                          class="text-xs px-2 py-1 rounded-md border bg-slate-800/60 text-slate-300 border-slate-700 cursor-pointer hover:border-amber-500/50 hover:text-amber-200 transition
                            <%= session.completed? ? 'line-through opacity-60' : '' %>"
                          data-action="click->session-modal#openFromPill"
                          data-title="<%= h session.title %>"
                          data-session-type="<%= h session.session_type %>"
                          data-intensity="<%= h session.intensity %>"
                          data-duration="<%= session.estimated_duration_minutes %>"
                          data-status="<%= h session.status %>"
                          data-description="<%= h session.description %>"
                          data-session-url="<%= weekly_plan_planned_session_path(wp, session) %>"
                          data-exercises="<%= h (session.exercises || []).to_json %>">
                          <span class="font-medium"><%= day_abbrevs[session.day_of_week] %></span>
                          <%= session.title %>
                          <% if session.completed? %>✓<% end %>
                        </button>
                      <% end %>
                    <% end %>
                  </div>
                </details>
              <% end %>
            </div>
          <% end %>
        </div>
      </details>
    </div>

    <!-- Regenerate Modal for this block -->
    <div class="fixed inset-0 z-50 hidden" data-regenerate-modal-target="overlay">
      <div class="absolute inset-0 bg-slate-950/80" data-action="click->regenerate-modal#close"></div>
      <div class="absolute inset-0 flex items-center justify-center p-4">
        <div class="bg-slate-900 border border-slate-700 rounded-2xl p-6 w-full max-w-lg relative">
          <h3 class="text-lg font-semibold">Regenerate Future Sessions</h3>
          <p class="text-sm text-slate-400 mt-2">Past and completed sessions will remain unchanged. Only future sessions will be regenerated.</p>
          <%= form_with url: regenerate_training_block_path(block), method: :post, class: "mt-4" do |f| %>
            <label class="block text-sm font-medium text-slate-300 mb-2">Comments or adjustments</label>
            <textarea name="comments" rows="4" placeholder="e.g. I want to focus more on endurance, reduce hangboard volume..."
              class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:border-amber-500"></textarea>
            <div class="mt-4 flex items-center justify-end gap-3">
              <button type="button" class="text-sm text-slate-400 hover:text-slate-200" data-action="click->regenerate-modal#close">Cancel</button>
              <button type="submit" class="bg-amber-500 text-slate-950 px-4 py-2 rounded-md text-sm font-semibold hover:bg-amber-400 transition">Regenerate</button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Completed Training Blocks (archive) -->
  <% if @completed_blocks.any? %>
    <div class="mt-2">
      <h3 class="text-lg font-semibold text-slate-300 mb-4">Completed Blocks</h3>
      <div class="space-y-3">
        <% @completed_blocks.each do |block| %>
          <div class="bg-slate-900/60 border border-slate-800 rounded-xl p-4 opacity-80 hover:opacity-100 transition">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div class="flex items-center gap-3">
                <div class="flex items-center justify-center w-8 h-8 rounded-full bg-slate-700/50 text-slate-400">
                  <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <div class="font-semibold text-sm text-slate-200"><%= block.name %></div>
                  <div class="text-xs text-slate-400 mt-0.5 flex items-center gap-2">
                    <span class="uppercase tracking-wide"><%= block.focus.humanize %></span>
                    <span>·</span>
                    <% end_date = block.ends_at || (block.started_at + block.weeks_planned.weeks if block.started_at && block.weeks_planned) %>
                    <span><%= block.started_at&.strftime("%b %d") %> – <%= end_date&.strftime("%b %d, %Y") %></span>
                    <% if block.weeks_planned %>
                      <span>·</span>
                      <span><%= block.weeks_planned %> weeks</span>
                    <% end %>
                  </div>
                </div>
              </div>
              <span class="text-xs bg-slate-700/50 text-slate-400 px-2 py-1 rounded-full">Completed</span>
            </div>
            <% if block.overall_focus.present? %>
              <p class="mt-2 text-slate-400 text-xs"><%= block.overall_focus %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Session Detail Modal -->
  <div class="fixed inset-0 z-50 hidden" data-session-modal-target="overlay" data-action="click->session-modal#closeOnBackdrop">
    <div class="absolute inset-0 bg-slate-950/80"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-slate-900 border border-slate-700 rounded-2xl p-6 w-full max-w-2xl relative max-h-[80vh] overflow-y-auto" data-session-modal-target="body">
      </div>
    </div>
  </div>
</div>
