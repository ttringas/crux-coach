<div id="<%= dom_id(profile, :training_block_generation) %>">
  <div class="rounded-xl border border-red-500/30 bg-red-500/5 p-4">
    <div class="text-xs uppercase tracking-wide text-red-300">Generation failed</div>
    <div class="text-sm text-slate-200 mt-1"><%= message.presence || "We couldn't generate your plan." %></div>
    <div class="text-xs text-slate-400 mt-2">Please try again. If this keeps happening, contact support.</div>
  </div>
</div>
