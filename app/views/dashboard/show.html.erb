<div class="space-y-8">
  <div>
    <h1 class="text-2xl font-semibold"><%= @greeting %>, <%= current_user.name.presence || current_user.email %></h1>
    <p class="text-slate-400 text-sm"><%= @today.strftime("%A, %B %d, %Y") %></p>
  </div>

  <div class="grid lg:grid-cols-3 gap-6">
    <!-- Today's Session -->
    <div class="lg:col-span-2 bg-slate-900 border border-slate-800 rounded-2xl p-6 transition hover:border-slate-700">
      <h2 class="text-lg font-semibold">Today</h2>
      <% if @today_session %>
        <div class="mt-4 rounded-xl border border-amber-500/40 bg-amber-500/5 p-5">
          <div class="text-sm text-slate-400 uppercase tracking-wide"><%= @today_session.session_type %> · <%= @today_session.intensity.humanize %></div>
          <div class="text-2xl font-semibold mt-2"><%= @today_session.title %></div>
          <p class="text-slate-300 mt-2"><%= @today_session.description.presence || "Session details ready in the plan." %></p>
          <div class="mt-4 text-sm text-slate-400">Estimated <%= @today_session.estimated_duration_minutes || "-" %> min</div>
          <div class="mt-5 flex flex-wrap gap-3">
            <%= link_to(@today_session.completed? ? "Review Session" : "Start Session", weekly_plan_planned_session_path(@current_plan, @today_session), class: "bg-amber-500 text-slate-950 px-5 py-2 rounded-md font-semibold hover:bg-amber-400 active:bg-amber-600 transition") %>
            <%= link_to "View Plan", calendar_path, class: "border border-slate-700 px-4 py-2 rounded-md text-slate-200" %>
          </div>
        </div>
      <% elsif @current_plan %>
        <div class="mt-4 text-slate-300">Rest day — no session scheduled.</div>
        <div class="mt-4">
          <%= link_to "View Plan", calendar_path, class: "border border-slate-700 px-4 py-2 rounded-md text-slate-200" %>
        </div>
      <% else %>
        <div class="mt-4 text-slate-300">No plan yet. Complete onboarding to generate your first week.</div>
      <% end %>
    </div>

    <!-- Training Block -->
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 transition hover:border-slate-700">
      <h2 class="text-lg font-semibold">Training Block</h2>
      <% if @training_block %>
        <div class="mt-4">
          <div class="text-sm text-slate-400 uppercase tracking-wide"><%= @training_block.focus.humanize %></div>
          <div class="text-xl font-semibold mt-2"><%= @training_block.name %></div>
          <div class="text-sm text-slate-400 mt-2">Week <%= @current_week %> of <%= @training_block.weeks_planned || "-" %></div>
          <p class="text-slate-300 mt-4"><%= @training_block.ai_reasoning.presence || "Plan tuned to your current focus." %></p>
        </div>
      <% else %>
        <div class="mt-4 text-slate-300">Training block will appear once your first plan is generated.</div>
      <% end %>
    </div>
  </div>

  <!-- Weekly Calendar with Sessions -->
  <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 transition hover:border-slate-700">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold">This Week</h2>
      <% if @current_plan %>
        <%= link_to "Full Calendar →", calendar_path, class: "text-amber-400 text-sm" %>
      <% end %>
    </div>
    <div class="grid grid-cols-7 gap-2">
      <% @week_dates.each_with_index do |date, day_idx| %>
        <% session = @planned_sessions_by_day[day_idx] %>
        <% is_today = date == @today %>
        <% is_past = date < @today %>
        <div class="rounded-xl border p-3 text-center transition
          <%= is_today ? 'border-amber-500/60 ring-1 ring-amber-500/30 bg-amber-500/5' : 'border-slate-700 bg-slate-800/40' %>
          <%= is_past && !is_today ? 'opacity-60' : '' %>">
          <div class="text-xs text-slate-400"><%= date.strftime("%a") %></div>
          <div class="text-lg font-semibold mt-1 <%= is_today ? 'text-amber-400' : 'text-slate-100' %>"><%= date.strftime("%d") %></div>
          <% if session %>
            <% status_color = case session.status
              when "completed" then "text-emerald-400"
              when "in_progress" then "text-amber-400"
              when "skipped" then "text-slate-500"
              else "text-slate-300"
            end %>
            <% if @current_plan %>
              <%= link_to weekly_plan_planned_session_path(@current_plan, session), class: "block mt-2 group" do %>
                <div class="text-[10px] uppercase tracking-wide <%= status_color %>"><%= session.session_type %></div>
                <div class="text-xs text-slate-300 group-hover:text-amber-400 transition truncate mt-0.5"><%= session.title.split(" ").first(2).join(" ") %></div>
              <% end %>
            <% end %>
          <% else %>
            <div class="text-[10px] text-slate-500 uppercase tracking-wide mt-2">Rest</div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="grid lg:grid-cols-2 gap-6">
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 transition hover:border-slate-700">
      <h2 class="text-lg font-semibold">Recent Sessions</h2>
      <div class="mt-4 space-y-4">
        <% if @recent_sessions.any? %>
          <% @recent_sessions.each do |log| %>
            <div class="flex items-center justify-between border-b border-slate-800 pb-3">
              <div>
                <div class="text-slate-100 font-semibold"><%= log.session_type.humanize %></div>
                <div class="text-xs text-slate-400"><%= log.date.strftime("%b %d, %Y") %></div>
              </div>
              <%= link_to "View", session_log_path(log), class: "text-amber-400 text-sm" %>
            </div>
          <% end %>
        <% else %>
          <div class="text-slate-300">No sessions logged yet.</div>
        <% end %>
      </div>
    </div>

    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 transition hover:border-slate-700">
      <h2 class="text-lg font-semibold">Quick Actions</h2>
      <div class="mt-4 grid gap-3">
        <% if @today_session && !@today_session.completed? %>
          <%= link_to "Start Today's Session", weekly_plan_planned_session_path(@current_plan, @today_session), class: "bg-amber-500 text-slate-950 px-4 py-2 rounded-md font-semibold hover:bg-amber-400 active:bg-amber-600 transition" %>
        <% end %>
        <%= link_to "View Plan", calendar_path, class: "border border-slate-700 px-4 py-2 rounded-md text-slate-200" %>
        <%= link_to "Edit Profile", edit_profile_path, class: "border border-slate-700 px-4 py-2 rounded-md text-slate-200" %>
        <%= link_to "Browse Coaches", coaches_path, class: "border border-slate-700 px-4 py-2 rounded-md text-slate-200" %>
      </div>
    </div>
  </div>
</div>
