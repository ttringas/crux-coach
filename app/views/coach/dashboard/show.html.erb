<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-semibold">Coach Dashboard</h1>
    <p class="text-slate-400 text-sm">Manage athletes and review current plans.</p>
  </div>

  <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6">
    <h2 class="text-lg font-semibold">Athletes</h2>
    <div class="mt-4 space-y-4">
      <% if @athletes.any? %>
        <% @athletes.each do |athlete| %>
          <div class="flex items-center justify-between border-b border-slate-800 pb-3">
            <div>
              <div class="text-slate-100 font-semibold"><%= athlete.user.name.presence || athlete.user.email %></div>
              <div class="text-xs text-slate-400">Current max boulder: <%= athlete.current_max_boulder_grade || "-" %></div>
            </div>
            <%= link_to "View", coach_athlete_path(athlete), class: "text-amber-400 text-sm" %>
          </div>
        <% end %>
      <% else %>
        <div class="text-slate-300">No athletes assigned yet.</div>
      <% end %>
    </div>
  </div>
</div>
