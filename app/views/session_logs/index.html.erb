<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-semibold">Session History</h1>
    <p class="text-slate-400 text-sm">Review and filter past sessions.</p>
  </div>
  <%= link_to "Log Session", new_session_log_path, class: "bg-amber-500 text-slate-950 px-4 py-2 rounded-md font-semibold" %>
</div>

<div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 mb-6">
  <%= form_with url: session_logs_path, method: :get, class: "grid md:grid-cols-4 gap-4" do %>
    <div>
      <label class="text-sm text-slate-300">Session type</label>
      <%= select_tag :session_type, options_for_select(SessionLog.session_types.keys.map { |k| [k.humanize, k] }, params[:session_type]), include_blank: "All", class: "mt-2 w-full rounded-md bg-slate-800 border border-slate-700 px-3 py-2" %>
    </div>
    <div>
      <label class="text-sm text-slate-300">From</label>
      <%= date_field_tag :date_from, params[:date_from], class: "mt-2 w-full rounded-md bg-slate-800 border border-slate-700 px-3 py-2" %>
    </div>
    <div>
      <label class="text-sm text-slate-300">To</label>
      <%= date_field_tag :date_to, params[:date_to], class: "mt-2 w-full rounded-md bg-slate-800 border border-slate-700 px-3 py-2" %>
    </div>
    <div class="flex items-end">
      <%= submit_tag "Filter", class: "bg-amber-500 text-slate-950 px-4 py-2 rounded-md font-semibold w-full" %>
    </div>
  <% end %>
</div>

<div class="space-y-4">
  <% if @session_logs.any? %>
    <% @session_logs.each do |log| %>
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-4 flex items-center justify-between">
        <div>
          <div class="text-slate-100 font-semibold"><%= log.session_type.humanize %></div>
          <div class="text-xs text-slate-400"><%= log.date.strftime("%b %d, %Y") %> · <%= log.duration_minutes || "-" %> min</div>
        </div>
        <%= link_to "View", session_log_path(log), class: "text-amber-400 text-sm" %>
      </div>
    <% end %>
  <% else %>
    <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 text-slate-300">No sessions yet.</div>
  <% end %>
</div>
