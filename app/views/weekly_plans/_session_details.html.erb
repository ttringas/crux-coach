<div class="text-sm text-slate-300">
  <p><%= session.description.presence || "No detailed description yet." %></p>
  <% if session.exercises.present? %>
    <div class="mt-3">
      <div class="text-slate-400 uppercase text-xs">Exercises</div>
      <ul class="mt-2 space-y-1">
        <% session.exercises.each do |exercise| %>
          <li class="text-slate-200"><%= exercise["name"] || exercise["title"] || "Exercise" %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
