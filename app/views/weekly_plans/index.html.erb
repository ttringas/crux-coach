<% selected_week = @selected_week_of || @weekly_plan&.week_of || Date.current.beginning_of_week(:monday) %>
<% prev_week = selected_week - 7 %>
<% next_week = selected_week + 7 %>

<div class="flex flex-col gap-6">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-semibold">Week of <%= selected_week.strftime("%b %d, %Y") %></h1>
      <div class="flex items-center gap-2">
        <%= link_to "←", weekly_plans_path(week_of: prev_week), class: "flex h-9 w-9 items-center justify-center rounded-md border border-slate-700 text-slate-300 hover:border-slate-500 hover:text-slate-100 transition", aria: { label: "Previous week" } %>
        <%= link_to "→", weekly_plans_path(week_of: next_week), class: "flex h-9 w-9 items-center justify-center rounded-md border border-slate-700 text-slate-300 hover:border-slate-500 hover:text-slate-100 transition", aria: { label: "Next week" } %>
      </div>
    </div>
    <%= form_with url: weekly_plans_path, method: :post, data: { controller: "plan-generator" }, class: "flex flex-col items-end gap-3" do %>
      <div class="w-full rounded-xl border border-slate-800 bg-slate-900 p-4">
        <div class="text-sm font-medium text-slate-300">Training Days</div>
        <div class="mt-3 flex flex-wrap gap-3">
          <% [
            ["Mon", 0],
            ["Tue", 1],
            ["Wed", 2],
            ["Thu", 3],
            ["Fri", 4],
            ["Sat", 5],
            ["Sun", 6]
          ].each do |label, value| %>
            <label class="flex items-center gap-2 rounded-md border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-100">
              <%= check_box_tag "training_days[]", value, true, class: "h-4 w-4 rounded border-slate-700 bg-slate-900 text-amber-500 accent-amber-500 focus:ring-amber-500" %>
              <span><%= label %></span>
            </label>
          <% end %>
        </div>
      </div>
      <div class="mt-4 w-full rounded-xl border border-slate-800 bg-slate-900 p-4">
        <div class="text-sm font-medium text-slate-300">Activities</div>
        <div class="mt-3 flex flex-wrap gap-3">
          <% [
            ["Bouldering", "bouldering"],
            ["Rope Climbing", "rope_climbing"],
            ["Board Climbing", "board_climbing"],
            ["Hangboarding", "hangboarding"],
            ["Strength Training", "strength_training"],
            ["Cardio", "cardio"],
            ["Mobility", "mobility"]
          ].each do |label, value| %>
            <label class="flex items-center gap-2 rounded-md border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-100">
              <%= check_box_tag "activities[]", value, true, class: "h-4 w-4 rounded border-slate-700 bg-slate-900 text-amber-500 accent-amber-500 focus:ring-amber-500" %>
              <span><%= label %></span>
            </label>
          <% end %>
        </div>
      </div>
      <%= button_tag "Generate Next Week", type: "submit",
        class: "bg-amber-500 text-slate-950 px-4 py-2 rounded-md font-semibold hover:bg-amber-400 active:bg-amber-600 transition",
        data: { action: "click->plan-generator#submit", plan_generator_target: "button" } %>
      <div class="hidden flex items-center gap-2 text-sm text-slate-300" data-plan-generator-target="status">
        <span class="h-4 w-4 rounded-full border-2 border-amber-500 border-t-transparent animate-spin"></span>
        <span>Generating your plan... This usually takes 30-60 seconds.</span>
      </div>
    <% end %>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    <div class="lg:col-span-2">
      <% if @weekly_plan %>
        <p class="text-slate-400 text-sm">Current week overview and session detail.</p>
      <% else %>
        <p class="text-slate-400 text-sm">No plan found for this week.</p>
      <% end %>
    </div>
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 transition hover:border-slate-700">
      <h2 class="text-lg font-semibold">Training Block</h2>
      <% if @training_block %>
        <div class="mt-4">
          <div class="text-sm text-slate-400 uppercase tracking-wide"><%= @training_block.focus.humanize %></div>
          <div class="text-xl font-semibold mt-2"><%= @training_block.name %></div>
          <div class="text-sm text-slate-400 mt-2">Week <%= @training_block.week_number || "-" %> of <%= @training_block.weeks_planned || "-" %></div>
          <p class="text-slate-300 mt-4"><%= @training_block.ai_reasoning.presence || "Plan tuned to your current focus." %></p>
        </div>
      <% else %>
        <div class="mt-4 text-slate-300">Training block will appear once your first plan is generated.</div>
      <% end %>
    </div>
  </div>

  <% if @weekly_plan %>
    <%= render "week_grid", weekly_plan: @weekly_plan, week_dates: @week_dates, planned_sessions: @planned_sessions %>
  <% else %>
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-10 text-center text-slate-300 transition hover:border-slate-700">
      <div class="text-lg font-semibold text-slate-100">No plan for this week yet.</div>
      <div class="mt-2 text-sm text-slate-400">Generate a plan to fill this week.</div>
      <div class="mt-6 flex justify-center">
        <%= form_with url: weekly_plans_path, method: :post, data: { controller: "plan-generator" } do %>
          <div class="w-full rounded-xl border border-slate-800 bg-slate-900 p-4">
            <div class="text-sm font-medium text-slate-300">Training Days</div>
            <div class="mt-3 flex flex-wrap gap-3">
              <% [
                ["Mon", 0],
                ["Tue", 1],
                ["Wed", 2],
                ["Thu", 3],
                ["Fri", 4],
                ["Sat", 5],
                ["Sun", 6]
              ].each do |label, value| %>
                <label class="flex items-center gap-2 rounded-md border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-100">
                  <%= check_box_tag "training_days[]", value, true, class: "h-4 w-4 rounded border-slate-700 bg-slate-900 text-amber-500 accent-amber-500 focus:ring-amber-500" %>
                  <span><%= label %></span>
                </label>
              <% end %>
            </div>
          </div>
          <div class="mt-4 w-full rounded-xl border border-slate-800 bg-slate-900 p-4">
            <div class="text-sm font-medium text-slate-300">Activities</div>
            <div class="mt-3 flex flex-wrap gap-3">
              <% [
                ["Bouldering", "bouldering"],
                ["Rope Climbing", "rope_climbing"],
                ["Board Climbing", "board_climbing"],
                ["Hangboarding", "hangboarding"],
                ["Strength Training", "strength_training"],
                ["Cardio", "cardio"],
                ["Mobility", "mobility"]
              ].each do |label, value| %>
                <label class="flex items-center gap-2 rounded-md border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-100">
                  <%= check_box_tag "activities[]", value, true, class: "h-4 w-4 rounded border-slate-700 bg-slate-900 text-amber-500 accent-amber-500 focus:ring-amber-500" %>
                  <span><%= label %></span>
                </label>
              <% end %>
            </div>
          </div>
          <%= button_tag "Generate Plan", type: "submit",
            class: "bg-amber-500 text-slate-950 px-6 py-2 rounded-md font-semibold hover:bg-amber-400 active:bg-amber-600 transition",
            data: { action: "click->plan-generator#submit", plan_generator_target: "button" } %>
          <div class="hidden mt-3 flex items-center justify-center gap-2 text-sm text-slate-300" data-plan-generator-target="status">
            <span class="h-4 w-4 rounded-full border-2 border-amber-500 border-t-transparent animate-spin"></span>
            <span>Generating your plan... This usually takes 30-60 seconds.</span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
