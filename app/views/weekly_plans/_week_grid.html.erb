<div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 transition hover:border-slate-700" data-controller="plan-drag" data-plan-drag-group-value="weekly-plan-sessions">
  <div class="flex items-center justify-between text-sm text-slate-400">
    <div>Week of <span class="text-slate-200"><%= weekly_plan.week_of.strftime("%b %d, %Y") %></span></div>
    <div>Status: <span class="text-amber-400"><%= weekly_plan.status %></span></div>
  </div>
  <div class="mt-6 grid gap-4">
    <% week_dates.each_with_index do |date, index| %>
      <% sessions = planned_sessions[index] || [] %>
      <div class="bg-slate-800/60 border border-slate-700 rounded-xl p-4 transition hover:border-slate-600"
           data-day-index="<%= index %>">
        <div class="flex items-center justify-between">
          <div>
            <div class="text-sm text-slate-400"><%= date.strftime("%A") %></div>
            <div class="text-lg font-semibold"><%= date.strftime("%b %d") %></div>
          </div>
          <div class="text-xs px-2 py-1 rounded-full border border-slate-700 text-slate-300">
            <%= sessions.any? ? "Sessions" : "Rest" %>
          </div>
        </div>

        <div class="mt-4 min-h-24 space-y-3 rounded-lg border border-dashed border-slate-700/80 p-2"
             data-plan-drag-target="sessionList">
          <% if sessions.any? %>
            <% sessions.each do |session| %>
              <% total_exercises = session.exercises.size %>
              <% completed_exercises = session.exercise_logs.count { |log| log["completed"] } %>
              <% status = session.status || "todo" %>
              <% status_classes = case status
                when "completed" then "border-green-500/30 bg-green-500/5"
                when "in_progress" then "border-amber-500/30 bg-amber-500/5"
                when "skipped" then "border-slate-600/60 bg-slate-800/60"
                else "border-slate-700 bg-slate-900"
              end %>
              <div class="rounded-lg border p-4 transition hover:border-slate-500 select-none <%= status_classes %>"
                   data-plan-drag-target="session"
                   data-session-id="<%= session.id %>"
                   data-update-url="<%= weekly_plan_planned_session_path(weekly_plan, session) %>"
                   data-day-index="<%= session.day_of_week %>"
                   data-position="<%= session.position || 0 %>">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <% if status == "todo" %>
                      <span class="h-2 w-2 rounded-full bg-slate-500"></span>
                    <% elsif status == "in_progress" %>
                      <span class="h-3 w-3 rounded-full border-2 border-amber-400 border-t-transparent animate-spin"></span>
                    <% elsif status == "completed" %>
                      <span class="h-4 w-4 rounded-full border border-green-400 text-green-300 flex items-center justify-center text-[10px]">✓</span>
                    <% else %>
                      <span class="h-4 w-4 rounded-full border border-slate-500 text-slate-300 flex items-center justify-center text-[10px]">–</span>
                    <% end %>
                    <div>
                      <div class="text-sm text-slate-400 uppercase tracking-wide"><%= session.session_type %> · <%= session.intensity.humanize %></div>
                      <div class="text-slate-100 font-semibold"><%= session.title %></div>
                    </div>
                  </div>
                  <div class="text-xs text-slate-400"><%= session.estimated_duration_minutes || "-" %> min</div>
                </div>
                <div class="mt-3 flex items-center justify-between text-xs text-slate-400">
                  <span><%= total_exercises.positive? ? "#{completed_exercises}/#{total_exercises} exercises done" : "No exercises logged" %></span>
                  <span class="uppercase tracking-wide"><%= status.humanize %></span>
                </div>
                <div class="mt-4 flex items-center justify-between">
                  <div class="flex items-center gap-2 text-[11px] uppercase tracking-wide text-slate-500" data-drag-handle>
                    <span class="cursor-grab text-slate-400">⋮⋮</span>
                    <span>Drag to reschedule</span>
                  </div>
                  <%= link_to "Go To Session", weekly_plan_planned_session_path(weekly_plan, session), class: "text-xs font-semibold text-slate-900 bg-amber-400 px-3 py-1.5 rounded-md hover:bg-amber-300 transition" %>
                </div>
              </div>
            <% end %>
          <% end %>
          <div class="text-sm text-slate-400 <%= sessions.any? ? "hidden" : "" %> py-6 text-center"
               data-plan-drag-target="emptyState">Drop a session here or leave it as a rest day.</div>
        </div>
      </div>
    <% end %>
  </div>

  <% if weekly_plan.coach_notes.present? %>
    <div class="mt-6 bg-slate-900 border border-amber-500/30 rounded-xl p-4 text-sm text-amber-200">
      Coach notes: <%= weekly_plan.coach_notes %>
    </div>
  <% end %>
</div>
