<div class="max-w-5xl mx-auto">
  <h1 class="text-2xl font-semibold mb-4">AI Usage (Today)</h1>

  <div class="grid md:grid-cols-3 gap-4 mb-8">
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-4 transition hover:border-slate-700">
      <div class="text-sm text-slate-400 uppercase tracking-wide">Total spend</div>
      <div class="text-2xl font-semibold text-slate-100">$<%= ((@total_spend_cents || 0) / 100.0).round(2) %></div>
    </div>
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-4 transition hover:border-slate-700">
      <div class="text-sm text-slate-400 uppercase tracking-wide">Total calls</div>
      <div class="text-2xl font-semibold text-slate-100"><%= @total_calls %></div>
    </div>
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-4 transition hover:border-slate-700">
      <div class="text-sm text-slate-400 uppercase tracking-wide">Daily budget</div>
      <div class="text-2xl font-semibold text-slate-100">$<%= (Rails.configuration.x.ai.daily_budget_cents / 100.0).round(2) %></div>
    </div>
  </div>

  <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 transition hover:border-slate-700">
    <h2 class="text-lg font-semibold mb-4">Top Users</h2>
    <% if @top_users.any? %>
      <div class="divide-y divide-slate-800">
        <% @top_users.each do |row| %>
          <div class="flex items-center justify-between py-3 text-sm text-slate-300">
            <div>
              <div class="text-slate-100 font-medium"><%= row.name.presence || row.email %></div>
              <div class="text-slate-500"><%= row.email %></div>
            </div>
            <div class="text-right">
              <div class="text-slate-100"><%= row.calls %> calls</div>
              <div class="text-slate-400">$<%= (row.spend_cents.to_i / 100.0).round(2) %></div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-slate-400 text-sm">No AI usage recorded today.</div>
    <% end %>
  </div>
</div>
