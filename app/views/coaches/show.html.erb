<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-semibold"><%= @coach.user.name.presence || @coach.user.email %></h1>
      <p class="text-slate-400 text-sm">Coach profile and specialties.</p>
    </div>
    <%= link_to "Back", coaches_path, class: "text-amber-400" %>
  </div>

  <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 space-y-6">
    <div>
      <div class="text-amber-400 text-xs uppercase">Bio</div>
      <p class="text-slate-300 mt-2"><%= @coach.bio.presence || "No bio yet." %></p>
    </div>
    <div class="grid md:grid-cols-3 gap-4 text-sm text-slate-300">
      <div>
        <div class="text-slate-400">Years coaching</div>
        <div class="text-slate-100"><%= @coach.years_coaching || "-" %></div>
      </div>
      <div>
        <div class="text-slate-400">Max boulder</div>
        <div class="text-slate-100"><%= @coach.max_grade_boulder || "-" %></div>
      </div>
      <div>
        <div class="text-slate-400">Max sport</div>
        <div class="text-slate-100"><%= @coach.max_grade_sport || "-" %></div>
      </div>
    </div>
    <div>
      <div class="text-slate-400 text-sm">Specialties</div>
      <div class="mt-2 text-slate-100"><%= @coach.specialties.join(", ").presence || "General" %></div>
    </div>

    <div>
      <button class="bg-amber-500 text-slate-950 px-6 py-2 rounded-md font-semibold">Request Coaching</button>
    </div>
  </div>
</div>
