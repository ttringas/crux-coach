<div class="min-h-screen bg-slate-950 text-slate-100 flex items-center justify-center px-4 md:px-6 py-16">
  <div class="w-full max-w-md bg-slate-900 border border-slate-800 rounded-2xl p-8 shadow-xl transition hover:border-slate-700">
    <h1 class="text-2xl font-semibold">Create your account</h1>
    <p class="text-sm text-slate-400 mt-2">Start with a quick profile and get your first plan.</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <div class="mt-6 space-y-4">
        <div>
          <%= f.label :name, class: "text-sm text-slate-300" %>
          <%= f.text_field :name, autofocus: true, placeholder: "Alex Johnson", class: "mt-2 w-full rounded-lg bg-slate-800 border border-slate-700 px-3 py-2 text-slate-100" %>
        </div>
        <div>
          <%= f.label :email, class: "text-sm text-slate-300" %>
          <%= f.email_field :email, autocomplete: "email", placeholder: "you@example.com", class: "mt-2 w-full rounded-lg bg-slate-800 border border-slate-700 px-3 py-2 text-slate-100" %>
        </div>
        <div>
          <%= f.label :password, class: "text-sm text-slate-300" %>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••", class: "mt-2 w-full rounded-lg bg-slate-800 border border-slate-700 px-3 py-2 text-slate-100" %>
        </div>
        <div>
          <%= f.label :password_confirmation, class: "text-sm text-slate-300" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••", class: "mt-2 w-full rounded-lg bg-slate-800 border border-slate-700 px-3 py-2 text-slate-100" %>
        </div>
      </div>

      <%= f.submit "Get Started", class: "mt-6 w-full bg-amber-500 text-slate-950 font-semibold py-2 rounded-md hover:bg-amber-400 active:bg-amber-600 transition" %>
    <% end %>

    <div class="mt-6 text-sm text-slate-400">
      Already have an account?
      <%= link_to "Sign in", new_user_session_path, class: "text-amber-400" %>
    </div>
  </div>
</div>
