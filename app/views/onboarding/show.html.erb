<div class="max-w-4xl mx-auto">
  <div class="mb-8">
    <div class="flex items-center justify-between text-sm text-slate-400">
      <span>Step <%= @step %> of 7</span>
      <span><%= ((@step.to_f / 7) * 100).round %>%</span>
    </div>
    <div class="mt-3 h-2 bg-slate-800 rounded-full">
      <div class="h-2 bg-amber-500 rounded-full transition-all duration-300" style="width: <%= ((@step.to_f / 7) * 100).round %>%"></div>
    </div>
  </div>

  <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8 transition hover:border-slate-700">
    <%= render "onboarding/step#{@step}", profile: @profile %>
  </div>
</div>
